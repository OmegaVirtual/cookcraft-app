@inject SignInManager<ApplicationUser> SignInManager
@using Recipes.Models

@{
    var hasExternalLogins = (await SignInManager.GetExternalAuthenticationSchemesAsync()).Any();
}

<ul class="nav flex-column gap-2">
    <li class="nav-item">
        <a class="nav-link custom-nav @ManageNavPages.IndexNavClass(ViewContext)" id="profile" asp-page="./Index">
            <i class="bi bi-person me-2"></i>Profile
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link custom-nav @ManageNavPages.EmailNavClass(ViewContext)" id="email" asp-page="./Email">
            <i class="bi bi-envelope-at me-2"></i>Email
        </a>
    </li>
    <li class="nav-item">
        <a class="nav-link custom-nav @ManageNavPages.ChangePasswordNavClass(ViewContext)" id="change-password" asp-page="./ChangePassword">
            <i class="bi bi-lock-fill me-2"></i>Password
        </a>
    </li>
    @if (hasExternalLogins)
    {
        <li class="nav-item">
            <a class="nav-link custom-nav @ManageNavPages.ExternalLoginsNavClass(ViewContext)" id="external-login" asp-page="./ExternalLogins">
                <i class="bi bi-box-arrow-in-right me-2"></i>External logins
            </a>
        </li>
    }
    <li class="nav-item">
        <a class="nav-link custom-nav @ManageNavPages.TwoFactorAuthenticationNavClass(ViewContext)" id="two-factor" asp-page="./TwoFactorAuthentication">
            <i class="bi bi-shield-lock me-2"></i>Two-factor authentication
        </a>
    </li>
</ul>

<style>
    .custom-nav {
        font-size: 1.1rem;
        font-weight: 600;
        color: #0f172a !important; /* Very dark text */
        background-color: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 50px;
        padding: 0.75rem 1.25rem;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
    }

        .custom-nav:hover,
        .custom-nav.active {
            background-color: var(--accent);
            color: white !important;
            border-color: var(--accent);
        }

        .custom-nav i {
            font-size: 1.2rem;
        }
</style>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
