@page
@model Recipes.Areas.Identity.Pages.Account.Manage.SettingsModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Settings";
}

<section class="py-5 pb-6" style="background-color: var(--background);">
    <div class="container-fluid px-4">
        <div class="row">
            <!-- Sidebar Navigation (Top-Left Aligned) -->
            <div class="col-lg-3 mb-5 d-flex flex-column align-items-start">
                <div class="w-100">
                    <a class="btn btn-outline-primary btn-xl rounded-pill fw-bold w-100 mb-3" asp-page="./Index">
                        <i class="bi bi-person-circle me-2"></i>Profile
                    </a>
                    <a class="btn btn-accent btn-xl rounded-pill fw-bold text-white w-100" asp-page="./Settings">
                        <i class="bi bi-gear me-2"></i>Settings
                    </a>
                </div>
            </div>

            <!-- Settings Form -->
            <div class="col-lg-9">
                <h2 class="fw-bold display-4 mb-4" style="color: var(--primary);">
                    <i class="bi bi-gear-fill me-2"></i>Account Settings
                </h2>
                <partial name="_StatusMessage" for="StatusMessage" />

                <div class="card shadow-lg border-0 rounded-4 p-5" style="background-color: #ffffff; color: #0f172a;">
                    <form method="post" enctype="multipart/form-data">
                        <div class="row">
                            <!-- Profile Picture Upload -->
                            <div class="col-md-4 text-center mb-4">
                                <label class="form-label fw-bold mb-2">📸 Profile Picture</label>
                                <img src="@(!string.IsNullOrEmpty(Model.ProfilePictureUrl) ? Model.ProfilePictureUrl : "/images/default-profile.png")"
                                     alt="Profile Picture"
                                     class="rounded-circle shadow mb-3"
                                     style="width: 160px; height: 160px; object-fit: cover; border: 4px solid var(--accent);" />
                                <input type="file" asp-for="Upload" class="form-control form-control-lg rounded-pill" />
                            </div>

                            <!-- Preferences and Input Fields -->
                            <div class="col-md-8">
                                <!-- Email Address -->
                                <div class="form-group mb-4">
                                    <label asp-for="Email" class="form-label fw-semibold">📧 Email Address</label>
                                    <input asp-for="Email" class="form-control form-control-lg border-2 shadow-sm" style="color: #0f172a;" />
                                    <span asp-validation-for="Email" class="text-danger small"></span>
                                </div>

                                <!-- Diet Option Dropdown -->
                                <div class="form-group mb-4">
                                    <label asp-for="DietOption" class="form-label fw-semibold">🍽️ Dietary Preference</label>
                                    <select asp-for="DietOption" class="form-select form-select-lg rounded-pill border-2 shadow-sm" style="color: #0f172a;">
                                        <option value="">-- Select Diet --</option>
                                        <option>Vegan</option>
                                        <option>Vegetarian</option>
                                        <option>Keto</option>
                                        <option>Paleo</option>
                                        <option>Standard</option>
                                        <option>Mediterranean</option>
                                        <option>Low-Carb</option>
                                        <option>High-Protein</option>
                                        <option>Gluten-Free</option>
                                        <option>Dairy-Free</option>
                                        <option>Pescatarian</option>
                                        <option>Flexitarian</option>
                                    </select>
                                </div>

                                <!-- Submit Buttons -->
                                <div class="d-flex justify-content-between align-items-center mt-5">
                                    <a asp-page="./ChangePassword" class="btn btn-outline-secondary btn-xl rounded-pill px-5 py-3 fw-semibold">
                                        <i class="bi bi-key me-2"></i>Change Password
                                    </a>
                                    <button type="submit" class="btn btn-xl rounded-pill px-5 py-3 fw-semibold text-white" style="background-color: var(--accent);">
                                        <i class="bi bi-save me-2"></i>Save Settings
                                    </button>
                                </div>
                            </div>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .btn-xl {
        font-size: 1.25rem;
        padding: 1.1rem 2.2rem;
    }

    .btn-accent {
        background-color: var(--accent);
        border: none;
    }

    .btn-outline-primary {
        border: 2px solid var(--primary);
        color: var(--primary);
        background-color: transparent;
    }

        .btn-outline-primary:hover {
            background-color: var(--primary);
            color: #fff;
        }

    input.form-control-lg,
    select.form-select-lg {
        font-size: 1.1rem;
        background-color: #ffffff;
    }

    .form-label {
        color: var(--primary);
        font-size: 1rem;
    }

    .container.pb-6 {
        padding-bottom: 6rem !important;
    }
</style>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
