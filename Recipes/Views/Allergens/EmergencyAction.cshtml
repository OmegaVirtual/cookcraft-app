@{
    ViewData["Title"] = "Emergency Actions for " + ViewBag.AllergenName;
}

<div class="container py-5 text-center">
    <h1 class="fw-bold display-5" style="color: var(--primary);">
        <i class="bi bi-hospital-fill me-2"></i>Emergency Actions
    </h1>
    <h3 class="text-muted mb-4">for <span class="text-danger fw-semibold">@ViewBag.AllergenName</span></h3>

    <div class="alert alert-danger shadow-sm rounded-4 px-4 py-4 mb-5" role="alert" style="font-size: 1.25rem; max-width: 800px; margin: auto;">
        <i class="bi bi-exclamation-octagon-fill me-2"></i>@ViewBag.Advice
    </div>

    <div class="text-center">
        <a asp-action="Index" class="btn btn-lg text-white rounded-pill px-4 py-2" style="background-color: var(--accent);">
            <i class="bi bi-arrow-left me-2"></i>Back to Allergen Management
        </a>
    </div>
</div>

<!-- Include Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

@section Scripts {
    <script>
        // Optional animation or emergency notification fade-in
        document.querySelector('.alert-danger')?.classList.add('animate__animated', 'animate__pulse');
    </script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
}