@model Recipes.Models.ApplicationUser

@{
    ViewData["Title"] = $"{Model.UserName}'s Profile";

    var recipes = ViewBag.Recipes as List<Recipes.Models.Recipe> ?? new List<Recipes.Models.Recipe>();
    var count = ViewBag.RecipeCount is int c ? c : 0;

    string level = "🍳 Kitchen Noob";
    if (count >= 20) level = "👨‍🍳 Master Chef";
    else if (count >= 10) level = "🥘 Skilled Cook";
    else if (count >= 3) level = "🍳 Home Chef";

    int nextGoal = 3;
    if (count >= 3 && count < 10) nextGoal = 10;
    else if (count >= 10 && count < 20) nextGoal = 20;
    else if (count >= 20) nextGoal = 30;

    int progressPercent = nextGoal > 0 ? (count * 100 / nextGoal) : 0;
    if (progressPercent > 100) progressPercent = 100;

    var mostPopular = recipes
        .OrderByDescending(r => r.Views)
        .FirstOrDefault();

    bool fiveDayStreak = ViewBag.FiveDayStreak is bool s && s;
}

<style>
    /* MOBILE FIRST FIXES */
    @@media (max-width: 575px) {

        .profile-header {
            padding: 1.5rem !important;
            flex-direction: column !important;
            text-align: center !important;
        }

            .profile-header h1 {
                font-size: 1.7rem !important;
                word-break: break-word;
            }

            .profile-header p {
                font-size: 0.95rem !important;
                word-break: break-all;
            }

        .profile-img {
            width: 120px !important;
            height: 120px !important;
        }

        .stat-pill {
            width: 100%;
            justify-content: center;
            text-align: center;
            font-size: 0.9rem !important;
        }

        .achievement-card {
            min-width: 100% !important;
        }

        .recipe-img {
            height: 160px !important;
        }
    }

    /* Premium CookCraft Styling */
    .profile-header {
        background: linear-gradient(135deg, var(--primary), var(--accent));
        padding: 2.3rem;
        border-radius: 25px;
        color: white;
        box-shadow: 0 10px 25px rgba(0,0,0,0.18);
        position: relative;
        overflow: hidden;
    }

        .profile-header::after {
            content: "";
            position: absolute;
            top: -40px;
            right: -40px;
            width: 220px;
            height: 220px;
            background: rgba(255,255,255,0.18);
            border-radius: 50%;
            filter: blur(6px);
        }

    .profile-img {
        width: 140px;
        height: 140px;
        border-radius: 50%;
        object-fit: cover;
        border: 5px solid rgba(255,255,255,0.4);
    }

    .stat-pill {
        background: rgba(255,255,255,0.25);
        padding: 0.6rem 1rem;
        border-radius: 18px;
        font-weight: 600;
        backdrop-filter: blur(5px);
        display: flex;
        align-items: center;
        gap: 0.3rem;
        flex-wrap: wrap;
    }

    .level-badge {
        background: white;
        color: var(--primary);
        padding: 0.5rem 1rem;
        font-weight: 700;
        border-radius: 20px;
        display: inline-block;
        box-shadow: 0 4px 10px rgba(0,0,0,0.15);
    }

    .achievement-card {
        border-radius: 16px;
        background: #fff;
        padding: 1rem;
        box-shadow: 0 4px 18px rgba(0,0,0,0.09);
        flex: 1;
        min-width: 240px;
    }

    .recipe-card {
        border-radius: 18px;
        overflow: hidden;
        background: white;
        box-shadow: 0 4px 18px rgba(0,0,0,0.1);
        transition: .3s;
    }

        .recipe-card:hover {
            transform: translateY(-4px);
            box-shadow: 0 6px 24px rgba(0,0,0,0.15);
        }

    .recipe-img {
        height: 200px;
        object-fit: cover;
    }

    .section-title {
        font-size: 2rem;
        font-weight: 700;
        color: var(--primary);
    }
</style>

<div class="container py-4">

    <!-- HEADER -->
    <div class="profile-header mb-5 d-flex align-items-center gap-4 flex-wrap">
        <img src="@(Model.ProfilePictureUrl ?? "/uploads/defaults/default1.jpg")" class="profile-img" />

        <div style="flex: 1;">
            <h1 class="fw-bold">@Model.UserName</h1>
            <p class="mb-2"><i class="bi bi-envelope"></i> @Model.Email</p>

            <div class="d-flex flex-wrap gap-3 mt-2">
                <div class="stat-pill">🥗 <b>Diet:</b> @Model.DietOption</div>
                <div class="stat-pill">📅 <b>Joined:</b> @Model.RegistrationDate.ToString("yyyy-MM-dd")</div>
                <div class="stat-pill">📚 <b>Recipes:</b> @count</div>
            </div>

            <div class="mt-3 level-badge">@level</div>

            <div class="mt-4">
                <label class="fw-semibold">Progress to next level</label>
                <div class="progress rounded-pill" style="height: 14px;">
                    <div class="progress-bar" style="width:@progressPercent%; background: var(--accent);"></div>
                </div>
                <div class="small mt-1">@count / @nextGoal recipes</div>
            </div>
        </div>
    </div>

    <!-- MOST POPULAR RECIPE -->
    @if (mostPopular != null)
    {
        <div class="mb-5">
            <h3 class="section-title"><i class="bi bi-fire me-2"></i>Most Popular Recipe</h3>

            <div class="card recipe-card">
                <img src="@mostPopular.ImageUrl" class="recipe-img" />
                <div class="card-body text-center">
                    <h4 class="fw-bold">@mostPopular.Title</h4>
                    <p class="text-muted small">@mostPopular.ShortDescription</p>

                    <span class="badge bg-warning text-dark rounded-pill px-3 py-2">
                        ⭐ @mostPopular.Views views
                    </span>

                    <div class="mt-3">
                        <a asp-controller="Recipes" asp-action="View" asp-route-id="@mostPopular.Id"
                           class="btn btn-outline-primary rounded-pill px-4">
                            View Recipe
                        </a>
                    </div>
                </div>
            </div>
        </div>
    }

    <!-- ACHIEVEMENTS -->
    <h3 class="section-title mb-3"><i class="bi bi-trophy me-2"></i>Achievements</h3>

    <div class="d-flex flex-wrap gap-3 mb-5">
        <div class="achievement-card">
            <h5>🏅 First Recipe Added</h5>
            <span class="badge @(count >= 1 ? "bg-success" : "bg-secondary") rounded-pill mt-2 px-3 py-2">
                @(count >= 1 ? "Unlocked" : "Locked")
            </span>
        </div>

        <div class="achievement-card">
            <h5>🔥 5-Day Cooking Streak</h5>
            <span class="badge @(fiveDayStreak ? "bg-success" : "bg-secondary") rounded-pill mt-2 px-3 py-2">
                @(fiveDayStreak ? "Unlocked" : "Locked")
            </span>
        </div>

        <div class="achievement-card">
            <h5>🌟 Premium Contributor</h5>
            <span class="badge @(count >= 10 ? "bg-success" : "bg-secondary") rounded-pill mt-2 px-3 py-2">
                @(count >= 10 ? "Unlocked" : "Locked")
            </span>
        </div>
    </div>

    <!-- USER RECIPES -->
    <h3 class="section-title mb-3"><i class="bi bi-book me-2"></i>@Model.UserName's Recipes</h3>

    @if (recipes.Any())
    {
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var recipe in recipes)
            {
                <div class="col">
                    <div class="card recipe-card">
                        <img src="@recipe.ImageUrl" class="recipe-img" />
                        <div class="card-body text-center">
                            <h5 class="fw-bold text-wrap">@recipe.Title</h5>
                            <p class="text-muted small text-wrap">@recipe.ShortDescription</p>

                            <a asp-controller="Recipes" asp-action="View" asp-route-id="@recipe.Id"
                               class="btn btn-outline-primary rounded-pill px-3 py-1">
                                View Recipe
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center">
            This user hasn’t added any recipes yet.
        </div>
    }
</div>
