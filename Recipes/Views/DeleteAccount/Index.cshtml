@{
    ViewData["Title"] = "Delete Your CookCraft Account";
}

<div class="container py-5">
    <h1 class="fw-bold mb-4">Delete Your CookCraft Account</h1>

    <p class="mb-3">
        You can delete your CookCraft account at any time using the
        <strong>"Delete My Account"</strong> button inside the app under:
    </p>

    <p class="fw-semibold">⚙️ Account → Settings → Delete My Account</p>

    <p class="mb-4">
        This will permanently remove your profile, recipes, preferences, and all associated data.
    </p>

    <h4 class="mt-4">Need help?</h4>
    <p>
        Email us at:
        <a href="mailto:cookcraft@mail.uk">cookcraft@mail.uk</a>
        and we will delete your account within 48 hours.
    </p>
</div>
