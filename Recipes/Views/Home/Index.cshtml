@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- 🌟 Hero Section -->
<div class="container py-4 mt-3 animate-fade-slide" style="max-width: 1050px;">
    <div class="hero-card text-center p-4 shadow-lg rounded-4 mb-4">
        <img src="~/uploads/CookCraftLogo.png" alt="CookCraft Logo" class="hero-logo mb-3" />
        <h1 class="fw-bold mb-2 display-6" id="animatedMessage" style="color: var(--accent);">
            🍽️ Welcome to CookCraft
        </h1>
        <p class="lead text-light mb-0" style="font-size: 1rem; color: #f0f0f0;">
            Your intelligent kitchen companion for recipes, grocery planning, and nutritional wellness.
        </p>
    </div>

    <!-- ✨ Features Section -->
    <div class="text-center mb-4 animate-fade">
        <h2 class="fw-bold mb-2" style="color: var(--accent); font-size: 1.6rem;">
            <i class="bi bi-lightning-charge-fill me-2"></i>Experience Premium Tools
        </h2>
        <p class="text-muted small">Craft smarter meals, manage allergens, and level up your cooking lifestyle.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-3">
        <div class="col d-flex">
            <div class="feature-card card h-100 text-center p-3 border-0 shadow rounded-4 bg-dark text-light w-100 d-flex flex-column justify-content-between animate-fade">
                <div>
                    <div class="mb-2 fs-3 glow-icon">🧠</div>
                    <h6 class="fw-bold mb-2" style="color: var(--primary); font-size: 1rem;">Smart Recipe Engine</h6>
                    <p class="text-muted small mb-3">Detect allergens, scale ingredients, and get instant nutrition insights.</p>
                </div>
                <a href="/Recipes/Index" class="btn premium-btn rounded-pill small-btn">📖 Recipes</a>
            </div>
        </div>
        <div class="col d-flex">
            <div class="feature-card card h-100 text-center p-3 border-0 shadow rounded-4 bg-dark text-light w-100 d-flex flex-column justify-content-between animate-fade delay-1">
                <div>
                    <div class="mb-2 fs-3 glow-icon">🧬</div>
                    <h6 class="fw-bold mb-2" style="color: var(--primary); font-size: 1rem;">Allergen Intelligence</h6>
                    <p class="text-muted small mb-3">Visualize data, personalize tracking, and ensure allergy-safe cooking.</p>
                </div>
                <a href="/Allergens/Index" class="btn premium-btn rounded-pill small-btn">🔎 Allergens</a>
            </div>
        </div>
        <div class="col d-flex">
            <div class="feature-card card h-100 text-center p-3 border-0 shadow rounded-4 bg-dark text-light w-100 d-flex flex-column justify-content-between animate-fade delay-2">
                <div>
                    <div class="mb-2 fs-3 glow-icon">📈</div>
                    <h6 class="fw-bold mb-2" style="color: var(--primary); font-size: 1rem;">Nutrition & Insights</h6>
                    <p class="text-muted small mb-3">Track calories, macros, and achievements with personalized stats.</p>
                </div>
                <a href="/Identity/Account/Manage/Index" class="btn premium-btn rounded-pill small-btn">👤 Profile</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const messages = [
            "🍽️ Welcome to CookCraft!",
            "📚 Organize and discover your favorite recipes.",
            "🔬 Analyze allergens and nutrition effortlessly.",
            "🔥 Track progress and earn achievements!"
        ];
        let index = 0;
        const msg = document.getElementById('animatedMessage');

        function rotateMessage() {
            msg.style.opacity = 0;
            setTimeout(() => {
                msg.textContent = messages[index];
                msg.style.opacity = 1;
                index = (index + 1) % messages.length;
            }, 400);
        }

        setInterval(rotateMessage, 4000);
    </script>

    <style>
        /* ✨ HERO */
        .hero-card {
            background: linear-gradient(135deg, rgba(46,139,87,0.9), rgba(255,127,80,0.85));
            backdrop-filter: blur(10px);
            border-radius: 16px;
            color: white;
            transition: transform 0.4s ease;
        }

            .hero-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.15);
            }

        .hero-logo {
            width: 70px;
            height: 70px;
            border-radius: 50%;
            background-color: white;
            padding: 4px;
            object-fit: cover;
        }

        /* ✨ Buttons */
        .premium-btn {
            background-color: var(--accent);
            color: #fff;
            font-weight: 600;
            font-size: 0.9rem;
            padding: 0.5rem 1rem;
            transition: all 0.3s ease;
        }

            .premium-btn:hover {
                background-color: var(--primary);
                color: #fff;
                transform: scale(1.05);
            }

        .small-btn {
            align-self: center;
            min-width: 110px;
        }

        /* ✨ Cards */
        .feature-card {
            background: rgba(31, 31, 31, 0.95);
            transition: transform 0.3s ease, box-shadow 0.3s ease;
            border-radius: 16px;
            min-height: 220px;
        }

            .feature-card:hover {
                transform: translateY(-4px);
                box-shadow: 0 8px 20px rgba(0,0,0,0.2);
            }

        .glow-icon {
            text-shadow: 0 0 10px rgba(255, 255, 255, 0.5), 0 0 18px var(--primary);
        }

        #animatedMessage {
            transition: opacity 0.5s ease-in-out;
        }

        /* ✨ Animations */
        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        @@keyframes fadeSlideIn {
            from {
                opacity: 0;
                transform: translateY(50px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        .animate-fade {
            opacity: 0;
            animation: fadeInUp 1s ease forwards;
        }

            .animate-fade.delay-1 {
                animation-delay: 0.3s;
            }

            .animate-fade.delay-2 {
                animation-delay: 0.6s;
            }

        .animate-fade-slide {
            opacity: 0;
            animation: fadeSlideIn 1.2s ease forwards;
        }

        /* 📱 Responsive */
        @@media (max-width: 992px) {
            .display-6 {
                font-size: 1.7rem;
            }

            .premium-btn {
                font-size: 0.85rem;
                padding: 0.45rem 0.9rem;
            }

            .hero-logo {
                width: 60px;
                height: 60px;
            }

            .feature-card {
                min-height: 200px;
            }
        }

        @@media (max-width: 576px) {
            .hero-card {
                padding: 2rem 1rem;
            }

            .display-6 {
                font-size: 1.4rem;
            }

            .lead {
                font-size: 0.9rem;
            }

            .premium-btn {
                font-size: 0.8rem;
                padding: 0.4rem 0.8rem;
            }

            .feature-card {
                min-height: 180px;
                padding: 1rem;
            }

            .hero-logo {
                width: 55px;
                height: 55px;
            }
        }

        @@media (max-width: 400px) {
            .display-6 {
                font-size: 1.2rem;
            }

            .lead {
                font-size: 0.85rem;
            }

            .hero-logo {
                width: 50px;
                height: 50px;
            }

            .feature-card {
                min-height: 160px;
            }
        }
    </style>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}
