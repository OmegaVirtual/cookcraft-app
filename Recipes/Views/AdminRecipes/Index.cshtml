@model List<Recipes.Models.Recipe>

@{
    ViewData["Title"] = "Manage Recipes";
}

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">

<div class="container py-4">

    <h1 class="fw-bold mb-4">
        <i class="bi bi-journal-text me-2"></i>
        Manage Recipes
    </h1>

    <div class="card shadow-sm p-3">
        <form method="get" class="d-flex mb-3">
            <input type="text" name="search" class="form-control me-2"
                   placeholder="Search recipes..."
                   value="@(Context.Request.Query["search"])" />


            <button class="btn btn-primary">Search</button>
        </form>

        <table class="table table-striped table-bordered align-middle text-center">
            <thead class="table-dark">
                <tr>
                    <th>Image</th>
                    <th>Title</th>
                    <th>User</th>
                    <th>Category</th>
                    <th>Views</th>
                    <th>Flagged</th>
                    <th>Delete</th>
                </tr>
            </thead>

            <tbody>
                @foreach (var r in Model)
                {
                    <tr>
                        <td>
                            <img src="@r.ImageUrl"
                                 style="width:80px;height:60px;object-fit:cover;border-radius:6px;" />
                        </td>

                        <td class="fw-bold">@r.Title</td>

                        <td>@(r.ApplicationUser?.Email ?? "Unknown")</td>

                        <td>@r.Category</td>

                        <td>@r.Views</td>

                        <td>
                            @if (r.FlaggedForReview)
                            {
                                <span class="badge bg-danger">Flagged</span>
                            }
                            else
                            {
                                <span class="badge bg-success">OK</span>
                            }
                        </td>

                        <td>
                            <form asp-action="Delete" asp-route-id="@r.Id" method="post"
                                  onsubmit="return confirm('Delete this recipe permanently?');">
                                <button class="btn btn-sm btn-danger">
                                    <i class="bi bi-trash"></i>
                                </button>
                            </form>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

</div>
