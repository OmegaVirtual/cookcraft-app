@model Recipes.Models.ViewModels.IngredientPickerViewModel

@{
    ViewData["Title"] = "Find Recipes by Ingredients";
}

<section class="py-5" style="background-color: var(--background);">
    <div class="container">
        <!-- 🧂 Header -->
        <div class="text-center mb-5 animate-fade">
            <h1 class="fw-bold display-4" style="color: var(--primary);">
                <i class="bi bi-basket3-fill me-2"></i>Find Recipes by Ingredients
            </h1>
            <p class="fs-5 text-muted mb-0">
                Select one or more ingredients to explore recipes curated by <strong>CookCraft</strong>.
            </p>
        </div>

        <!-- ⚠️ Validation -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger shadow-sm rounded-pill text-center mx-auto" style="max-width: 500px;">
                @foreach (var error in ViewData.ModelState.Values.SelectMany(v => v.Errors))
                {
                    <div>@error.ErrorMessage</div>
                }
            </div>
        }

        <!-- 🥕 Ingredient Selector -->
        <form asp-action="PickIngredients" method="post" class="mb-5">
            @Html.AntiForgeryToken()

            <div class="ingredient-card shadow-sm p-4 rounded-4 bg-white animate-fade">
                <h5 class="fw-semibold mb-3" style="color: var(--accent);">
                    <i class="bi bi-egg-fried me-2"></i>Available Ingredients
                </h5>

                <div class="row row-cols-2 row-cols-md-3 row-cols-lg-4 g-3">
                    @{
                        var commonIngredients = new[]
                        {
                                        new { Name = "Flour", Icon = "bi-bag-fill", Color = "text-warning" },
                                        new { Name = "Butter", Icon = "bi-droplet-half", Color = "text-warning" },
                                        new { Name = "Eggs", Icon = "bi-egg-fried", Color = "text-warning" },
                                        new { Name = "Milk", Icon = "bi-cup-straw", Color = "text-primary" },
                                        new { Name = "Cheese", Icon = "bi-cup-hot", Color = "text-warning" },
                                        new { Name = "Chicken", Icon = "bi-drumstick", Color = "text-danger" },
                                        new { Name = "Beef", Icon = "bi-fire", Color = "text-danger" },
                                        new { Name = "Fish", Icon = "bi-water", Color = "text-info" },
                                        new { Name = "Rice", Icon = "bi-basket3-fill", Color = "text-secondary" },
                                        new { Name = "Pasta", Icon = "bi-emoji-smile", Color = "text-secondary" },
                                        new { Name = "Tomato", Icon = "bi-heart-fill", Color = "text-danger" },
                                        new { Name = "Onion", Icon = "bi-lightbulb", Color = "text-warning" },
                                        new { Name = "Garlic", Icon = "bi-lightning", Color = "text-warning" },
                                        new { Name = "Olive Oil", Icon = "bi-droplet", Color = "text-success" },
                                        new { Name = "Potato", Icon = "bi-square-fill", Color = "text-warning" }
                                        };
                    }

                    @for (int idx = 0; idx < commonIngredients.Length; idx++)
                    {
                        var ing = commonIngredients[idx];
                        var isChecked = Model.SelectedIngredients != null && Model.SelectedIngredients.Contains(ing.Name);

                        <div class="col">
                            <div class="ingredient-tile text-center p-3 rounded-4 shadow-sm bg-white hover-shadow"
                                 style="transition: all 0.3s ease;">
                                <input class="form-check-input d-none"
                                       type="checkbox"
                                       name="SelectedIngredients"
                                       value="@ing.Name"
                                       id="ing_@idx"
                                       @(isChecked ? "checked" : "") />

                                <label class="form-check-label d-block fw-semibold text-capitalize" for="ing_@idx">
                                    <i class="bi @ing.Icon fs-2 mb-2 @ing.Color"></i><br />
                                    @ing.Name
                                </label>
                            </div>
                        </div>
                    }
                </div>

                <div class="text-center mt-4">
                    <button type="submit"
                            class="btn btn-lg text-white rounded-pill fw-bold px-5 py-3 shadow-sm search-btn">
                        <i class="bi bi-search me-2"></i>Show Recipes
                    </button>
                </div>
            </div>
        </form>

        <!-- 🍲 Matching Recipes -->
        @if (Model.MatchingRecipes != null && Model.MatchingRecipes.Any())
        {
            <div class="results-section mt-5 animate-fade">
                <h3 class="fw-bold mb-4" style="color: var(--primary);">
                    <i class="bi bi-journal-check me-2"></i>Recipes Found (@Model.MatchingRecipes.Count)
                </h3>

                <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
                    @foreach (var recipe in Model.MatchingRecipes)
                    {
                        <div class="col">
                            <div class="card h-100 shadow-sm border-0 rounded-4 recipe-card">
                                <div class="recipe-img-wrapper">
                                    <img src="@recipe.ImageUrl"
                                         class="card-img-top rounded-top-4"
                                         alt="@recipe.Title" />
                                </div>

                                <div class="card-body d-flex flex-column p-4">
                                    <h5 class="card-title fw-bold" style="color: var(--accent);">
                                        <i class="bi bi-egg-fried me-1"></i>@recipe.Title
                                    </h5>
                                    <p class="card-text text-muted small mb-3">
                                        @recipe.ShortDescription
                                    </p>

                                    <div class="mt-auto d-flex justify-content-between">
                                        <a asp-controller="Recipes"
                                           asp-action="View"
                                           asp-route-id="@recipe.Id"
                                           class="btn btn-outline-secondary btn-sm rounded-pill px-3">
                                            <i class="bi bi-book me-1"></i>View Recipe
                                        </a>

                                        <button type="button"
                                                class="btn btn-sm rounded-pill px-3 text-white add-btn"
                                                onclick="addToGrocery(@recipe.Id)">
                                            <i class="bi bi-cart-plus me-1"></i>Add to Grocery
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        }
        else if (Model.MatchingRecipes == null || !Model.MatchingRecipes.Any())
        {
            <p class="text-center text-muted mt-4">No recipes found yet. Try selecting different ingredients!</p>
        }

        <!-- 🔙 Back Button -->
        <div class="text-center mt-5">
            <a href="javascript:history.back()"
               class="btn btn-outline-secondary rounded-pill px-4 py-2 shadow-sm back-btn">
                <i class="bi bi-arrow-left-circle me-2"></i>Back to Previous Page
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        function addToGrocery(recipeId) {
            fetch('/Grocery/AddRecipeIngredients/' + recipeId, {
                method: 'POST',
                headers: {
                    'RequestVerificationToken': document
                        .querySelector('input[name="__RequestVerificationToken"]').value,
                    'Content-Type': 'application/json'
                }
            })
            .then(res => {
                if (!res.ok) throw new Error('Network error');
                return res.json();
            })
            .then(data => {
                if (data.success) {
                    Swal.fire({
                        title: 'Added!',
                        text: 'Ingredients added to your grocery list.',
                        icon: 'success',
                        confirmButtonColor: '#2E8B57'
                    });
                } else {
                    Swal.fire('Oops!', 'Failed to add ingredients.', 'error');
                }
            })
            .catch(err => {
                console.error(err);
                Swal.fire('Error', 'Something went wrong while adding to grocery list.', 'error');
            });
        }
    </script>

    <style>
        /* ✨ Animation */
        .animate-fade {
            animation: fadeInUp 0.8s ease both;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* 🧺 Ingredient Tiles */
        .ingredient-tile {
            cursor: pointer;
            transition: all 0.3s ease-in-out;
            border: 2px solid transparent;
        }

            .ingredient-tile:hover {
                transform: translateY(-5px);
                box-shadow: 0 0.75rem 1.25rem rgba(0, 0, 0, 0.1);
            }

            .ingredient-tile input:checked + label,
            label:has(input:checked) {
                background: linear-gradient(90deg, var(--primary), var(--accent));
                color: white !important;
                border-radius: 1rem;
                box-shadow: 0 0 12px rgba(46, 139, 87, 0.5);
            }

        /* 🍲 Recipe Cards */
        .recipe-card {
            background-color: #fffdf9;
            transition: transform 0.25s ease, box-shadow 0.25s ease;
        }

            .recipe-card:hover {
                transform: translateY(-5px);
                box-shadow: 0 0.75rem 1.25rem rgba(0, 0, 0, 0.1);
            }

        .recipe-img-wrapper {
            height: 200px;
            overflow: hidden;
        }

            .recipe-img-wrapper img {
                height: 100%;
                width: 100%;
                object-fit: cover;
                transition: transform 0.4s ease;
            }

        .recipe-card:hover img {
            transform: scale(1.05);
        }

        .add-btn {
            background-color: var(--accent);
            border: none;
            transition: all 0.3s ease-in-out;
        }

            .add-btn:hover {
                background-color: #256d46;
            }

        .btn-outline-secondary {
            color: var(--accent);
            border-color: var(--accent);
        }

            .btn-outline-secondary:hover {
                color: #fff;
                background-color: var(--accent);
            }

        .search-btn {
            background: linear-gradient(90deg, var(--primary), var(--accent));
            border: none;
        }

            .search-btn:hover {
                background: linear-gradient(90deg, var(--accent), var(--primary));
                transform: translateY(-2px);
                box-shadow: 0 6px 16px rgba(46, 139, 87, 0.3);
            }

        /* 🔙 Back Button */
        .back-btn {
            color: var(--accent);
            border-color: var(--accent);
            transition: all 0.3s ease;
        }

            .back-btn:hover {
                background-color: var(--accent);
                color: #fff;
                transform: translateY(-2px);
                box-shadow: 0 4px 10px rgba(0,0,0,0.15);
            }
    </style>

    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
