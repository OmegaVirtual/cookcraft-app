@using System.Security.Claims
@model Recipes.Models.Recipe
@{
    ViewData["Title"] = Model.Title;
    var currentUserId = User.FindFirstValue(ClaimTypes.NameIdentifier);
    bool isOwner = Model.ApplicationUserId == currentUserId;
}

<div class="container py-5">
    <!-- HEADER -->
    <div class="row align-items-center mb-5">

        <!-- Image -->
        <div class="col-md-6 mb-4 mb-md-0">
            <div class="position-relative">
                <img src="@Model.ImageUrl"
                     alt="@Model.Title"
                     class="img-fluid rounded-4 shadow-lg w-100"
                     style="max-height:420px; object-fit:cover;">
                <span class="position-absolute top-0 end-0 bg-success text-white px-3 py-1 rounded-start-pill shadow-sm fw-semibold">
                    Imported from external source
                </span>

            </div>
        </div>

        <!-- Title + user -->
        <div class="col-md-6">
            <h1 class="fw-bold display-6">@Model.Title</h1>

            <div id="autoAllergenBox" class="alert alert-danger mt-3 d-none shadow-sm rounded-3">
                <h6 class="fw-bold mb-2">
                    <i class="bi bi-exclamation-triangle-fill me-1"></i> Contains Allergens:
                </h6>
                <div id="autoAllergenList"></div>
            </div>

            @if (Model.ApplicationUser != null)
            {
                <p class="mt-4 mb-1">
                    <i class="bi bi-person-circle text-success me-2"></i>
                    <strong>Added by:</strong>
                    <a asp-controller="Profile" asp-action="View" asp-route-id="@Model.ApplicationUser.Id"
                       class="link-success fw-bold text-decoration-none">@Model.ApplicationUser.UserName</a>
                </p>
            }
        </div>
    </div>

    <!-- INGREDIENTS -->
    @if (Model.Ingredients != null && Model.Ingredients.Any())
    {
        <div class="mb-5">
            <div class="d-flex align-items-center justify-content-between mb-3 flex-wrap gap-2">
                <h3 class="fw-bold text-success mb-0">
                    <i class="bi bi-basket2-fill me-2"></i> Ingredients
                </h3>

                <div class="d-flex align-items-center">
                    <label class="me-2 fw-semibold text-muted">Scale:</label>
                    <select id="scaleSelector" class="form-select form-select-sm w-auto shadow-sm">
                        <option value="0.5">½x</option>
                        <option value="1" selected>1x</option>
                        <option value="2">2x</option>
                        <option value="4">4x</option>
                        <option value="8">8x</option>
                    </select>
                </div>
            </div>

            <ul class="list-group list-group-flush rounded shadow-sm" id="ingredientList">
                @foreach (var item in Model.Ingredients)
                {
                    <li class="list-group-item d-flex align-items-center">
                        <i class="bi bi-check-circle text-success me-2"></i>
                        <span class="ingredient-text flex-grow-1">@item</span>
                    </li>
                }
            </ul>
        </div>
    }

    <!-- METHOD -->
    <div class="mb-5">
        <h3 class="fw-bold text-primary mb-3">
            <i class="bi bi-journal-text me-2"></i> Method of Cooking
        </h3>
        <div class="bg-light p-3 rounded shadow-sm">
            <pre class="m-0 text-dark fw-normal" style="white-space:pre-wrap;">@Model.Instructions</pre>
        </div>
    </div>

    <!-- NUTRITION -->
    <div id="nutritionSection" class="mt-5">
        <h3 class="fw-bold text-warning mb-3">
            <i class="bi bi-activity me-2"></i> Estimated Nutrition (total recipe)
        </h3>
        <div class="row g-3 text-center" id="macroCards">
            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                    <i class="bi bi-fire text-danger fs-2"></i>
                    <p class="fw-semibold mb-0">Calories</p>
                    <h5 id="calories">-- kcal</h5>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                    <i class="bi bi-droplet-half text-primary fs-2"></i>
                    <p class="fw-semibold mb-0">Fat</p>
                    <h5 id="fat">-- g</h5>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                    <i class="bi bi-egg-fried text-warning fs-2"></i>
                    <p class="fw-semibold mb-0">Protein</p>
                    <h5 id="protein">-- g</h5>
                </div>
            </div>

            <div class="col-6 col-md-3">
                <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                    <i class="bi bi-cup-straw text-success fs-2"></i>
                    <p class="fw-semibold mb-0">Carbs</p>
                    <h5 id="carbs">-- g</h5>
                </div>
            </div>
        </div>

        <div class="row g-3 text-center mt-3" id="microCards"></div>
    </div>

    <hr class="my-5" />

    <!-- ACTION BUTTONS -->
    <div class="d-flex flex-wrap gap-3 justify-content-center mt-4">
        <a asp-controller="Recipes" asp-action="Index"
           class="btn btn-outline-secondary rounded-pill px-4 py-2">
            <i class="bi bi-arrow-left-circle me-1"></i> Back to Recipe Library
        </a>

        @if (isOwner)
        {
            <a asp-controller="Recipes" asp-action="Edit" asp-route-id="@Model.Id"
               class="btn btn-outline-primary rounded-pill px-4 py-2">
                <i class="bi bi-pencil-square me-1"></i> Edit Recipe
            </a>

            <form asp-controller="Recipes" asp-action="Delete" asp-route-id="@Model.Id"
                  method="post" onsubmit="return confirm('Delete this recipe?');" class="d-inline">
                <button type="submit" class="btn btn-outline-danger rounded-pill px-4 py-2">
                    <i class="bi bi-trash me-1"></i> Delete
                </button>
            </form>
        }

        <button type="button" class="btn btn-success rounded-pill px-4 py-2" onclick="shareRecipe()">
            <i class="bi bi-share-fill me-1"></i> Share Recipe
        </button>
    </div>
</div>


<!-- JAVASCRIPT -->
@section Scripts {
    <script>

        /**************************
            INGREDIENT SCALING
        ***************************/
        const scaleSelector = document.getElementById("scaleSelector");
        const ingredientList = document.getElementById("ingredientList");
        const baseIngredients = Array.from(document.querySelectorAll(".ingredient-text")).map(el => el.textContent.toLowerCase());
        let currentScale = 1;

        scaleSelector?.addEventListener("change", function () {
            currentScale = parseFloat(this.value);

            ingredientList.querySelectorAll(".ingredient-text").forEach((el, i) => {
                el.textContent = scaleIngredient(baseIngredients[i], currentScale);
            });

            analyzeRecipe();
        });

        function scaleIngredient(text, scale) {
            return text.replace(/(\d+([.,]?\d+)?)/g, (m) => {
                const num = parseFloat(m.replace(",", "."));
                if (isNaN(num)) return m;
                return (num * scale).toFixed(1).replace(/\.0$/, "");
            });
        }


        /**************************
            ALLERGEN DETECTION
        ***************************/
        const allergenKeywords = {
            "milk": "Milk", "cheese": "Milk", "butter": "Milk", "cream": "Milk", "yogurt": "Milk",
            "egg": "Eggs", "mayo": "Eggs", "aioli": "Eggs",
            "fish": "Fish", "salmon": "Fish", "cod": "Fish", "tuna": "Fish",
            "shrimp": "Shellfish (Crustaceans)", "prawn": "Shellfish (Crustaceans)",
            "mussel": "Molluscs", "clam": "Molluscs", "oyster": "Molluscs", "squid": "Molluscs",
            "wheat": "Gluten", "flour": "Gluten", "bread": "Gluten", "pasta": "Gluten",
            "peanut": "Peanuts", "groundnut": "Peanuts",
            "almond": "Tree Nuts", "walnut": "Tree Nuts", "hazelnut": "Tree Nuts",
            "soy": "Soy", "soya": "Soy", "tofu": "Soy",
            "sesame": "Sesame", "tahini": "Sesame",
            "mustard": "Mustard", "dijon": "Mustard",
            "celery": "Celery",
            "lupin": "Lupin",
            "sulphite": "Sulphites", "sulfite": "Sulphites"
        };


        /**************************
             NUTRITION ENGINE
        ***************************/
        const nutritionDB = {
            "salmon": { kcal: 208, protein: 20, fat: 13, carbs: 0, salt: 0.1, fiber: 0, sugar: 0, calcium: 10, iron: 0.5, vitC: 0 },
            "potato": { kcal: 77, protein: 2, fat: 0, carbs: 17, salt: 0, fiber: 2.2, sugar: 1, calcium: 10, iron: 0.3, vitC: 20 },
            "flour": { kcal: 364, protein: 10, fat: 1, carbs: 76, salt: 0, fiber: 2, sugar: 0, calcium: 20, iron: 3, vitC: 0 },
            "egg": { kcal: 155, protein: 13, fat: 11, carbs: 1, salt: 0.4, fiber: 0, sugar: 1, calcium: 50, iron: 1.2, vitC: 0 },
            "milk": { kcal: 42, protein: 3.4, fat: 1, carbs: 5, salt: 0.1, fiber: 0, sugar: 5, calcium: 120, iron: 0, vitC: 0 }
        };


        /**************************
             FULL ANALYSIS
        ***************************/
        function analyzeRecipe() {
            const text = baseIngredients.join(" ");

            // Allergens
            let foundAllergens = [...new Set(
                Object.entries(allergenKeywords)
                    .filter(([k]) => text.includes(k))
                    .map(([_, v]) => v)
            )];

            const allergenBox = document.getElementById("autoAllergenBox");
            const allergenList = document.getElementById("autoAllergenList");

            if (foundAllergens.length) {
                allergenBox.classList.remove("d-none");
                allergenList.innerHTML = foundAllergens
                    .map(a => `<span class='badge bg-danger bg-opacity-75 me-1 mb-1'>${a}</span>`)
                    .join("");
            }

            // Nutrition totals
            let totals = { kcal: 0, protein: 0, fat: 0, carbs: 0, salt: 0, fiber: 0, sugar: 0, calcium: 0, iron: 0, vitC: 0 };

            Object.entries(nutritionDB).forEach(([k, v]) => {
                if (text.includes(k)) {
                    for (const key in v) totals[key] += v[key] * currentScale;
                }
            });

            document.getElementById("calories").textContent = `~${Math.round(totals.kcal)} kcal`;
            document.getElementById("fat").textContent = `${totals.fat.toFixed(1)} g`;
            document.getElementById("protein").textContent = `${totals.protein.toFixed(1)} g`;
            document.getElementById("carbs").textContent = `${totals.carbs.toFixed(1)} g`;

            document.getElementById("microCards").innerHTML = `
                    <div class='col-4 col-md-2 mx-auto'><div class='card border-0 shadow-sm rounded-4 p-2 bg-white'>
                    <i class='bi bi-droplet text-primary fs-5'></i><p class='small fw-semibold mb-0'>Salt</p><p class='fw-bold mb-0'>${totals.salt.toFixed(1)} g</p></div></div>
                    <div class='col-4 col-md-2 mx-auto'><div class='card border-0 shadow-sm rounded-4 p-2 bg-white'>
                    <i class='bi bi-flower2 text-success fs-5'></i><p class='small fw-semibold mb-0'>Fiber</p><p class='fw-bold mb-0'>${totals.fiber.toFixed(1)} g</p></div></div>
                    <div class='col-4 col-md-2 mx-auto'><div class='card border-0 shadow-sm rounded-4 p-2 bg-white'>
                    <i class='bi bi-cup-straw text-warning fs-5'></i><p class='small fw-semibold mb-0'>Sugar</p><p class='fw-bold mb-0'>${totals.sugar.toFixed(1)} g</p></div></div>
                    <div class='col-4 col-md-2 mx-auto'><div class='card border-0 shadow-sm rounded-4 p-2 bg-white'>
                    <i class='bi bi-droplet-half text-info fs-5'></i><p class='small fw-semibold mb-0'>Calcium</p><p class='fw-bold mb-0'>${totals.calcium.toFixed(0)} mg</p></div></div>
                    <div class='col-4 col-md-2 mx-auto'><div class='card border-0 shadow-sm rounded-4 p-2 bg-white'>
                    <i class='bi bi-moon-stars text-secondary fs-5'></i><p class='small fw-semibold mb-0'>Iron</p><p class='fw-bold mb-0'>${totals.iron.toFixed(1)} mg</p></div></div>
                    <div class='col-4 col-md-2 mx-auto'><div class='card border-0 shadow-sm rounded-4 p-2 bg-white'>
                    <i class='bi bi-sun-fill text-danger fs-5'></i><p class='small fw-semibold mb-0'>Vitamin C</p><p class='fw-bold mb-0'>${totals.vitC.toFixed(1)} mg</p></div></div>`;
        }

        /**************************
             SHARING
        ***************************/
        function shareRecipe() {
            if (navigator.share) {
                navigator.share({
                    title: '@Model.Title',
                    text: 'Check out this recipe!',
                    url: window.location.href
                });
            } else {
                navigator.clipboard.writeText(window.location.href);
                alert("Recipe link copied!");
            }
        }

        // Start processing
        analyzeRecipe();

    </script>
}

<!-- STYLES -->
<style>
    body {
        background: linear-gradient(135deg, #f5f9ff, #eafaf1);
    }

    .card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 18px rgba(0, 0, 0, 0.1);
    }

    .list-group-item {
        border: none;
        border-bottom: 1px solid #f0f0f0;
    }

        .list-group-item:last-child {
            border-bottom: none;
        }
</style>

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
