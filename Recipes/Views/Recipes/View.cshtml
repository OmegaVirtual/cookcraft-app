        const nutritionDB={
        // kcal, protein, fat, carbs, salt, fiber, sugar, calcium, iron, vitC
        "chicken":{kcal:239,protein:27,fat:14,carbs:0,salt:0.2,fiber:0,sugar:0,calcium:15,iron:1,vitC:0},
