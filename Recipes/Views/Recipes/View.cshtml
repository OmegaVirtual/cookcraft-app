        "banana":{kcal:89,protein:1,fat:0,carbs:23,salt:0,fiber:2.6,sugar:12,calcium:5,iron:0.3,vitC:9},
        "orange":{kcal:47,protein:1,fat:0,carbs:12,salt:0,fiber:2.4,sugar:9,calcium:40,iron:0.1,vitC:53},
        "garlic":{kcal:149,protein:6,fat:0,carbs:33,salt:0,fiber:2.1,sugar:1,calcium:181,iron:1.7,vitC:31},
        "onion":{kcal:40,protein:1,fat:0,carbs:9,salt:0,fiber:1.7,sugar:4,calcium:23,iron:0.2,vitC:8},
        "peas":{kcal:81,protein:5,fat:0,fiber:5,carbs:14,salt:0, sugar:6,calcium:25,iron:1.5,vitC:40},
        "bean":{kcal:347,protein:21,fat:1,carbs:63,salt:0,fiber:15,sugar:3,calcium:120,iron:5,vitC:0},
        "chickpea":{kcal:164,protein:9,fat:3,carbs:27,salt:0,fiber:8,sugar:5,calcium:49,iron:2.9,vitC:1},
        "lentil":{kcal:116,protein:9,fat:0,carbs:20,salt:0,fiber:8,sugar:1,calcium:19,iron:3.3,vitC:4},
        "avocado":{kcal:160,protein:2,fat:15,carbs:9,salt:0,fiber:7,sugar:0.7,calcium:12,iron:0.6,vitC:10},
