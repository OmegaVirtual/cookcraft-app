@model Recipes.Models.ViewModels.ShoppingListRequestViewModel
@{
    ViewData["Title"] = "Smart Grocery Generator";
}

<section class="generator-section py-5 pb-6">
    <div class="container">
        <div class="text-center mb-5 animate-fade">
            <h1 class="fw-bold display-4" style="color: var(--primary);">
                🧠 Smart Grocery Generator
            </h1>
            <p class="fs-5 text-muted">
                Answer a few quick questions and we’ll craft a balanced shopping list just for you!
            </p>
        </div>

        <div class="generator-card shadow-sm mx-auto p-5 rounded-4 animate-fade" style="max-width: 720px;">
            <form asp-action="Generate" method="post">
                @Html.AntiForgeryToken()

                <!-- 👨‍👩‍👧 Household Size -->
                <div class="mb-4">
                    <label class="form-label fw-semibold text-dark mb-1">
                        👨‍👩‍👧‍👦 How many people are in your household?
                    </label>
                    <input type="number" name="NumberOfPeople" id="householdSize"
                           class="form-control form-control-lg rounded-pill text-center"
                           value="1" min="1" max="20" readonly />
                </div>

                <!-- 🎂 Age Groups -->
                <div class="mb-4">
                    <label class="form-label fw-semibold text-dark mb-1">
                        🎂 Age group for each person
                    </label>
                    <div id="ageGroupsContainer">
                        <select name="AgeGroups" class="form-select form-select-lg rounded-pill mb-2" required>
                            <option value="Adult">Adult</option>
                            <option value="Child">Child</option>
                            <option value="Senior">Senior</option>
                            <option value="Baby">Baby</option>
                        </select>
                    </div>
                    <button type="button"
                            class="btn btn-sm rounded-pill fw-semibold mt-2 px-3 add-btn"
                            onclick="addAgeGroup()">
                        <i class="bi bi-person-plus"></i> Add Another Person
                    </button>
                </div>

                <!-- 📅 Duration -->
                <div class="mb-4">
                    <label class="form-label fw-semibold text-dark mb-1">
                        📅 How many days do you want the list for?
                    </label>
                    <select name="DurationInDays" id="duration"
                            class="form-select form-select-lg rounded-pill" required>
                        <option value="1">1 Day</option>
                        <option value="3">3 Days</option>
                        <option value="5">5 Days</option>
                        <option value="7">1 Week</option>
                    </select>
                </div>

                <!-- 🥦 Dietary Preference -->
                <div class="mb-5">
                    <label class="form-label fw-semibold text-dark mb-1">
                        🥦 Dietary Preference
                    </label>
                    <select name="DietPreference" id="diet"
                            class="form-select form-select-lg rounded-pill">
                        <option value="">None</option>
                        <option value="Vegetarian">Vegetarian</option>
                        <option value="Vegan">Vegan</option>
                        <option value="Gluten-Free">Gluten-Free</option>
                    </select>
                </div>

                <!-- ✨ Submit -->
                <div class="text-center mt-4">
                    <button type="submit"
                            class="btn btn-lg text-white rounded-pill fw-bold px-5 py-3 shadow submit-btn">
                        ✨ Generate My List
                    </button>
                </div>
            </form>
        </div>
    </div>
</section>

@section Scripts {
    <script>
        // Add new age group dynamically
        function addAgeGroup() {
            const container = document.getElementById("ageGroupsContainer");
            const select = document.createElement("select");
            select.name = "AgeGroups";
            select.className = "form-select form-select-lg rounded-pill mb-2";
            select.required = true;
            select.innerHTML = `
                <option value="Adult">Adult</option>
                <option value="Child">Child</option>
                <option value="Senior">Senior</option>
                <option value="Baby">Baby</option>
            `;
            container.appendChild(select);

            // Update household count
            const count = container.querySelectorAll("select").length;
            document.getElementById("householdSize").value = count;
        }
    </script>

    <style>
        /* 🪴 Background */
        .generator-section {
            background-color: var(--background);
            color: var(--text-dark);
        }

        /* 🍞 Card */
        .generator-card {
            background-color: #fffdf9;
            border: 2px solid rgba(255, 127, 80, 0.2);
            border-left: 6px solid var(--primary);
        }

        /* 🌿 Inputs */
        .form-select, .form-control {
            border: 1px solid #e0d7ce;
            color: var(--text-dark);
            background-color: #fff;
            transition: all 0.2s ease-in-out;
        }

            .form-select:focus, .form-control:focus {
                border-color: var(--accent);
                box-shadow: 0 0 0 3px rgba(46, 139, 87, 0.25);
            }

        /* ➕ Add button */
        .add-btn {
            background-color: var(--accent);
            color: #fff;
            border: none;
            transition: background-color 0.3s ease;
        }

            .add-btn:hover {
                background-color: #256d46;
            }

        /* ✨ Submit button */
        .submit-btn {
            background: linear-gradient(90deg, var(--primary), var(--accent));
            border: none;
            transition: transform 0.2s ease, box-shadow 0.3s ease;
        }

            .submit-btn:hover {
                transform: translateY(-2px);
                box-shadow: 0 6px 16px rgba(255, 127, 80, 0.35);
            }

        /* 🌟 Fade animation */
        .animate-fade {
            animation: fadeInUp 0.8s ease both;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translateY(30px);
            }

            to {
                opacity: 1;
                transform: translateY(0);
            }
        }

        /* 🍃 Text and labels */
        label {
            font-size: 1.05rem;
        }

        select.form-select-lg, input.form-control-lg {
            font-size: 1.1rem;
        }

        .btn:focus {
            box-shadow: 0 0 0 3px rgba(255, 127, 80, 0.3);
        }
    </style>
}

<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
