@page
@model Recipes.Areas.Identity.Pages.Account.LoginModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Login";
}

<section class="py-5" style="background: var(--background);">
    <div class="container px-3">

        <!-- HEADER -->
        <div class="text-center mb-5 fade-in">
            <h2 class="fw-bold display-5" style="color: var(--primary);">
                <i class="bi bi-door-open-fill me-2" style="color: var(--accent);"></i>
                Welcome Back 👋
            </h2>
            <p class="text-muted fs-5">Log in and continue your cooking journey.</p>
        </div>

        <!-- ERROR MESSAGE -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div class="alert alert-danger text-center fade-in-delayed" style="font-size: 1.1rem;">
                ⚠️ Incorrect username or password.
            </div>
        }

        <!-- LOGIN CARD -->
        <div class="row justify-content-center fade-in-delayed">
            <div class="col-md-7 col-lg-5">
                <div class="login-card shadow-lg rounded-4 p-5">

                    <form asp-route-returnUrl="@Model.ReturnUrl" method="post">

                        <!-- Username -->
                        <div class="mb-4">
                            <label asp-for="Input.Username" class="form-label premium-label">👤 Username</label>
                            <input asp-for="Input.Username"
                                   class="form-control form-control-lg premium-input"
                                   placeholder="Enter your username" />
                            <span asp-validation-for="Input.Username" class="text-danger small"></span>
                        </div>

                        <!-- Password -->
                        <div class="mb-4">
                            <label asp-for="Input.Password" class="form-label premium-label">🔒 Password</label>
                            <input asp-for="Input.Password"
                                   type="password"
                                   class="form-control form-control-lg premium-input"
                                   placeholder="Enter your password" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- REMEMBER ME -->
                        <div class="form-group mb-4 d-flex align-items-center">
                            <input asp-for="Input.RememberMe" class="form-check-input me-2" />
                            <label class="form-check-label" asp-for="Input.RememberMe">Remember me</label>
                        </div>

                        <!-- LOGIN BUTTON -->
                        <button type="submit"
                                class="btn login-btn w-100 text-white rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-box-arrow-in-right me-2"></i>
                            Login
                        </button>

                    </form>

                </div>
            </div>
        </div>

    </div>
</section>

<style>

    /* ✨ Fade animations */
    .fade-in {
        opacity: 0;
        animation: fadeIn .7s forwards ease-out;
    }

    .fade-in-delayed {
        opacity: 0;
        animation: fadeIn .9s forwards ease-out .15s;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* 🌟 Premium Login Card */
    .login-card {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(12px);
        border-radius: 28px;
        border: 1px solid rgba(255,255,255,0.4);
    }

    /* 🧁 Premium Label */
    .premium-label {
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--primary);
        margin-bottom: 0.4rem;
    }

    /* 🥥 Inputs */
    .premium-input {
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 0.95rem 1.1rem;
        font-size: 1.07rem;
        color: #0f172a;
        background: #fff;
        transition: 0.25s;
    }

        .premium-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 0.2rem rgba(46, 139, 87, 0.2);
        }

    /* 🌈 Login Button */
    .login-btn {
        background: linear-gradient(135deg, var(--primary), var(--accent));
        padding: 1rem;
        font-size: 1.3rem;
        transition: 0.2s ease;
        border: none;
    }

        .login-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(0,0,0,0.18);
        }

</style>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
