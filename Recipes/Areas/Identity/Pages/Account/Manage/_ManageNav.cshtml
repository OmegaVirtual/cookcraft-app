@using Recipes.Models

<ul class="nav flex-column gap-2">

    <!-- PROFILE LINK -->
    <li class="nav-item">
        <a class="nav-link custom-nav @ManageNavPages.IndexNavClass(ViewContext)"
           id="profile" asp-page="./Index">
            <i class="bi bi-person me-2"></i> Profile
        </a>
    </li>

    <!-- SETTINGS LINK -->
    <li class="nav-item">
        <a class="nav-link custom-nav @ManageNavPages.PersonalDataNavClass(ViewContext)"
           id="settings" asp-page="./PersonalData">
            <i class="bi bi-gear me-2"></i> Settings
        </a>
    </li>

</ul>

<style>
    .custom-nav {
        font-size: 1.1rem;
        font-weight: 600;
        color: #0f172a !important;
        background-color: #ffffff;
        border: 2px solid #e2e8f0;
        border-radius: 50px;
        padding: 0.75rem 1.25rem;
        transition: all 0.2s ease;
        display: flex;
        align-items: center;
    }

        .custom-nav:hover,
        .custom-nav.active {
            background-color: var(--accent);
            color: white !important;
            border-color: var(--accent);
        }

        .custom-nav i {
            font-size: 1.2rem;
        }
</style>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
