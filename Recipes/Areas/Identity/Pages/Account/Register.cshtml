@page
@model Recipes.Areas.Identity.Pages.Account.RegisterModel
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    ViewData["Title"] = "Register";
}

<section class="py-5" style="background: var(--background);">
    <div class="container px-3">

        <!-- HEADER -->
        <div class="text-center mb-5 fade-in">
            <h2 class="fw-bold display-5" style="color: var(--primary);">
                <i class="bi bi-stars me-2" style="color: var(--accent);"></i>
                Join CookCraft
            </h2>
            <p class="text-muted fs-5">Create your account and unlock your personal cooking universe.</p>
        </div>

        <!-- FORM CARD -->
        <div class="row justify-content-center fade-in-delayed">
            <div class="col-md-7 col-lg-6">
                <div class="register-card shadow-lg rounded-4 p-5">

                    <form asp-route-returnUrl="@Model.ReturnUrl" method="post">

                        <!-- Username -->
                        <div class="mb-4">
                            <label asp-for="Input.Username" class="form-label premium-label">👤 Username</label>
                            <input asp-for="Input.Username"
                                   class="form-control form-control-lg premium-input"
                                   placeholder="Choose a username" />
                            <span asp-validation-for="Input.Username" class="text-danger small"></span>
                        </div>

                        <!-- Email -->
                        <div class="mb-4">
                            <label asp-for="Input.Email" class="form-label premium-label">📧 Email</label>
                            <input asp-for="Input.Email"
                                   class="form-control form-control-lg premium-input"
                                   placeholder="you@example.com" />
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <!-- Diet -->
                        <div class="mb-4">
                            <label asp-for="Input.DietOption" class="form-label premium-label">🥗 Diet Preference</label>
                            <select asp-for="Input.DietOption"
                                    class="form-select form-select-lg premium-input">
                                <option value="">-- Select Diet --</option>
                                <option>Vegan</option>
                                <option>Vegetarian</option>
                                <option>Keto</option>
                                <option>Paleo</option>
                                <option>Standard</option>
                                <option>Mediterranean</option>
                                <option>Low-Carb</option>
                                <option>High-Protein</option>
                                <option>Gluten-Free</option>
                                <option>Dairy-Free</option>
                                <option>Pescatarian</option>
                                <option>Flexitarian</option>
                            </select>
                            <span asp-validation-for="Input.DietOption" class="text-danger small"></span>
                        </div>

                        <!-- Password -->
                        <div class="mb-4">
                            <label asp-for="Input.Password" class="form-label premium-label">🔒 Password</label>
                            <input asp-for="Input.Password"
                                   type="password"
                                   class="form-control form-control-lg premium-input"
                                   placeholder="Create a password" />
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- Confirm -->
                        <div class="mb-5">
                            <label asp-for="Input.ConfirmPassword" class="form-label premium-label">🔁 Confirm Password</label>
                            <input asp-for="Input.ConfirmPassword"
                                   type="password"
                                   class="form-control form-control-lg premium-input"
                                   placeholder="Repeat your password" />
                            <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                        </div>

                        <!-- Submit -->
                        <button type="submit"
                                class="btn register-btn w-100 text-white rounded-pill fw-bold shadow-sm">
                            <i class="bi bi-check-circle-fill me-2"></i>
                            Create Account
                        </button>
                    </form>

                </div>
            </div>
        </div>

    </div>
</section>

<style>

    /* ✨ Smooth fade-in animations */
    .fade-in {
        opacity: 0;
        animation: fadeIn 0.7s forwards ease-out;
    }

    .fade-in-delayed {
        opacity: 0;
        animation: fadeIn 0.8s forwards ease-out 0.15s;
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
            transform: translateY(20px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    /* 🎨 Premium Register Card */
    .register-card {
        background: rgba(255,255,255,0.9);
        backdrop-filter: blur(12px);
        border: 1px solid rgba(255,255,255,0.4);
        border-radius: 28px;
    }

    /* 🧁 Premium Label */
    .premium-label {
        font-weight: 700;
        font-size: 1.05rem;
        color: var(--primary);
        margin-bottom: 0.4rem;
    }

    /* 🥥 Inputs */
    .premium-input {
        border: 2px solid #e2e8f0;
        border-radius: 16px;
        padding: 0.95rem 1.1rem;
        background: #ffffff;
        color: #0f172a;
        transition: all .25s;
        font-size: 1.07rem;
    }

        .premium-input:focus {
            border-color: var(--accent);
            box-shadow: 0 0 0 0.2rem rgba(46, 139, 87, 0.2);
        }

    /* 🍃 Submit Button */
    .register-btn {
        font-size: 1.3rem;
        padding: 1rem;
        background: linear-gradient(135deg, var(--primary), var(--accent));
        transition: 0.2s ease;
        border: none;
    }

        .register-btn:hover {
            transform: translateY(-2px);
            box-shadow: 0 10px 28px rgba(0,0,0,0.18);
        }

</style>

<link rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
