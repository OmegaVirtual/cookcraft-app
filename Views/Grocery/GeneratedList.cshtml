@model IEnumerable<Recipes.Models.GroceryItem>

@{
    ViewData["Title"] = "Generated Grocery List";
}

<section class="py-5 pb-6" style="background-color: var(--background);">
    <div class="container">
        <div class="text-center mb-5">
            <h1 class="fw-bold display-4" style="color: var(--primary);">
                <i class="bi bi-cart-check-fill me-2"></i>Your Smart Grocery List
            </h1>
            <p class="text-muted fs-5">Here's a tailored grocery list based on your answers!</p>
        </div>

        <div class="row row-cols-1 row-cols-md-2 g-4">
            @foreach (var item in Model)
            {
                <div class="col animate__animated animate__fadeInUp">
                    <div class="card h-100 shadow-sm border-0 rounded-4 grocery-card bg-light">
                        <div class="card-body d-flex flex-column">
                            <h5 class="card-title mb-1 fw-bold fs-5">
                                @item.Name <span class="text-muted small">x @item.Quantity</span>
                            </h5>
                            <span class="badge bg-info text-dark mb-2 align-self-start">@item.Category</span>
                            @if (!string.IsNullOrWhiteSpace(item.Note))
                            {
                                <div class="text-muted small">⚡ @item.Note</div>
                            }
                        </div>
                    </div>
                </div>
            }
        </div>

        <div class="text-center mt-5">
            <a href="/Grocery/List" class="btn btn-xl btn-outline-secondary rounded-pill px-5 py-3 fs-5">
                <i class="bi bi-house-door me-2"></i>Back to Grocery Planner
            </a>
        </div>
    </div>
</section>

@section Scripts {
    <style>
        .btn-xl {
            font-size: 1.1rem;
            padding: 0.75rem 1.25rem;
        }

        .container.pb-6 {
            padding-bottom: 6rem !important;
        }

        .animate__animated {
            animation-duration: 1.2s;
            animation-fill-mode: both;
        }

        .animate__fadeInUp {
            animation-name: fadeInUp;
        }

        @@keyframes fadeInUp {
            from {
                opacity: 0;
                transform: translate3d(0, 40px, 0);
            }
            to {
                opacity: 1;
                transform: none;
            }
        }
    </style>
}

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
