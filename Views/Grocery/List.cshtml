@model IEnumerable<Recipes.Models.GroceryItem>

@{
    ViewData["Title"] = "Grocery Planner";
    var totalItems = Model.Count();
    var boughtItems = Model.Count(x => x.IsBought);
    var progress = totalItems > 0 ? (boughtItems * 100 / totalItems) : 0;

    var categoryCounts = Model
        .GroupBy(i => i.Category)
        .Select(g => new { Category = g.Key, Count = g.Count() })
        .ToList();

    var categoryLabels = string.Join(",", categoryCounts.Select(c => $"'{c.Category}'"));
    var categoryData = string.Join(",", categoryCounts.Select(c => c.Count));
    var listNames = ViewBag.AllListNames as List<string> ?? new List<string>();
}

<div class="text-center py-5 pb-6">
    <h1 class="fw-bold display-5" style="color: var(--primary);">🛒 Grocery Planner</h1>
    <p class="text-muted fs-5">Plan smart, shop smarter.</p>

    <!-- ✅ Progress Bar -->
    <div class="progress my-4 mx-auto" style="height: 28px; max-width: 500px;">
        <div class="progress-bar fw-bold" role="progressbar" style="width: @progress%; background-color: var(--accent);" aria-valuenow="@progress" aria-valuemin="0" aria-valuemax="100">
            @progress% Completed
        </div>
    </div>

    <!-- 🔍 Search Bar -->
    <form asp-action="List" method="get" class="d-flex justify-content-center gap-2 mb-4">
        <input type="text" name="searchTerm" class="form-control shadow-sm rounded-pill px-4 py-3 fs-5" placeholder="Search groceries..." style="max-width: 320px;" />
        <button type="submit" class="btn btn-xl btn-outline-primary rounded-pill px-4 py-2 fs-5"><i class="bi bi-search me-1"></i>Search</button>
    </form>

    <!-- 🚀 Link to Smart Generator -->
    <div class="mb-5">
        <a href="/Grocery/Generate" class="btn btn-xl text-white rounded-pill fw-bold px-5 py-3 fs-5" style="background-color: var(--accent);">
            <i class="bi bi-stars me-2"></i>Generate Smart Grocery List
        </a>
    </div>

    <!-- 🧩 Category Filters (Hidden) -->
    <div class="d-none">
        <div class="d-flex justify-content-center gap-2 mb-5 flex-wrap">
            @foreach (var category in new[] { "All", "Fruits", "Vegetables", "Meat", "Dairy", "Bakery", "Other" })
            {
                <a asp-action="List" asp-route-categoryFilter="@category" class="btn btn-xl btn-outline-success rounded-pill px-4 py-2 fs-6">@category</a>
            }
        </div>
    </div>

    <!-- ➕ Add Grocery Form -->
    <form asp-action="Add" method="post" class="row justify-content-center mb-5 g-3">
        <div class="col-md-3">
            <input type="text" name="name" class="form-control rounded-pill px-4 py-3 fs-5" placeholder="Item name..." required />
        </div>
        <div class="col-md-2">
            <input type="number" name="quantity" class="form-control rounded-pill px-4 py-3 fs-5" placeholder="Qty" value="1" min="1" />
        </div>
        <div class="col-md-2">
            <select name="category" class="form-select rounded-pill px-4 py-3 fs-5">
                <option value="Fruits">Fruits</option>
                <option value="Vegetables">Vegetables</option>
                <option value="Meat">Meat</option>
                <option value="Dairy">Dairy</option>
                <option value="Bakery">Bakery</option>
                <option value="Other">Other</option>
            </select>
        </div>
        <div class="col-md-3">
            <input type="text" name="note" class="form-control rounded-pill px-4 py-3 fs-5" placeholder="Optional note..." />
        </div>
        <div class="col-md-2 d-grid">
            <button type="submit" class="btn btn-xl text-white rounded-pill fw-bold px-4 py-3 fs-5" style="background-color: var(--accent);">
                <i class="bi bi-plus-circle me-1"></i>Add
            </button>
        </div>
    </form>

    <!-- 💾 Save/Load Named Lists (Hidden) -->
    <div class="d-none">
        <div class="row justify-content-center mb-5 g-3">
            <form asp-action="SaveList" method="post" class="col-md-4 d-flex gap-2">
                <input type="text" name="listName" class="form-control rounded-pill" placeholder="Save as..." required />
                <button type="submit" class="btn btn-outline-success rounded-pill">💾 Save</button>
            </form>
            <form asp-action="LoadList" method="post" class="col-md-4 d-flex gap-2">
                <select name="listName" class="form-select rounded-pill">
                    <option disabled selected>Choose list</option>
                    @foreach (var name in listNames)
                    {
                        <option value="@name">@name</option>
                    }
                </select>
                <button type="submit" class="btn btn-outline-info rounded-pill">📂 Load</button>
            </form>
        </div>
    </div>
</div>

<!-- ✅ Donut Chart for Category Breakdown -->
<div class="text-center my-5">
    <h4 class="fw-bold mb-3" style="color: var(--primary);">📊 Items by Category</h4>
    <canvas id="categoryChart" style="max-width: 400px; margin: auto;"></canvas>
</div>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success text-center fw-semibold">@TempData["SuccessMessage"]</div>
}
@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger text-center fw-semibold">@TempData["ErrorMessage"]</div>
}

<!-- ✅ Grocery List -->
<div class="container pb-6">
    <div class="row row-cols-1 row-cols-md-2 g-4">
        @foreach (var item in Model)
        {
            <div class="col">
                <div class="card h-100 shadow-sm border-0 rounded-4 grocery-card bg-light">
                    <div class="card-body d-flex flex-column">
                        <h5 class="card-title mb-1 @(item.IsBought ? "text-decoration-line-through text-success" : "") fs-4 text-dark">
                            @item.Name <span class="text-muted small">x @item.Quantity</span>
                        </h5>
                        <span class="badge bg-info text-dark mb-2 align-self-start">@item.Category</span>
                        @if (!string.IsNullOrWhiteSpace(item.Note))
                        {
                            <div class="text-muted fst-italic small mb-3">📝 @item.Note</div>
                        }
                        <div class="mt-auto d-flex justify-content-end gap-2">
                            <form asp-action="ToggleBought" asp-route-id="@item.Id" method="post">
                                <button type="submit" class="btn btn-xl btn-outline-success rounded-pill px-3 py-2 fs-6" title="Mark as bought">✔️</button>
                            </form>
                            <button type="button" class="btn btn-xl btn-outline-danger rounded-pill px-3 py-2 fs-6" onclick="confirmDelete('@item.Id', '@item.Name')">🗑️</button>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>


@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>

    <script>
        function confirmDelete(id, name) {
            Swal.fire({
                title: 'Are you sure?',
                text: `Do you want to delete "${name}"?`,
                icon: 'warning',
                showCancelButton: true,
                confirmButtonColor: '#0e7490',
                cancelButtonColor: '#d33',
                confirmButtonText: 'Yes, delete it!',
                cancelButtonText: 'Cancel'
            }).then((result) => {
                if (result.isConfirmed) {
                    const form = document.createElement('form');
                    form.method = 'post';
                    form.action = '/Grocery/Delete/' + id;
                    document.body.appendChild(form);
                    form.submit();
                }
            });
        }

        const categoryCtx = document.getElementById('categoryChart')?.getContext('2d');
        if (categoryCtx) {
            new Chart(categoryCtx, {
                type: 'doughnut',
                data: {
                    labels: [@Html.Raw(categoryLabels)],
                    datasets: [{
                        label: 'Item Count',
                        data: [@Html.Raw(categoryData)],
                        backgroundColor: ['#34d399', '#60a5fa', '#f87171', '#fbbf24', '#a78bfa', '#9ca3af'],
                        borderWidth: 1
                    }]
                },
                options: {
                    responsive: true,
                    plugins: {
                        legend: {
                            position: 'bottom'
                        }
                    }
                }
            });
        }
    </script>

    <style>
        .btn-xl {
            font-size: 1.1rem;
            padding: 0.75rem 1.25rem;
        }

        .container.pb-6 {
            padding-bottom: 6rem !important; /* ensures content is above footer/nav */
        }
    </style>
}

<!-- Include Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
