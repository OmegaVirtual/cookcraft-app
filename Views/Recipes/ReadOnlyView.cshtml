@model Recipes.Models.Recipe
@{
    ViewData["Title"] = "Shared Recipe";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-5" style="color: var(--primary);">
            <i class="bi bi-share-fill me-2"></i>@Model.Title
        </h1>
        <p class="text-muted fs-5">@Model.ShortDescription</p>
    </div>

    <div class="row justify-content-center">
        <div class="col-lg-8">
            <img src="@Model.ImageUrl" class="img-fluid rounded-4 shadow mb-4" alt="Recipe Image" style="width: 100%; object-fit: cover;" />

            @if (Model.Allergens != null && Model.Allergens.Count > 0)
            {
                <div class="card shadow-sm p-4 mb-4" style="background-color: #fff0f0; border-left: 6px solid #dc3545; border-radius: 1.5rem;">
                    <h4 class="fw-bold mb-3 text-danger">
                        <i class="bi bi-exclamation-triangle-fill me-2"></i>Contains Allergens
                    </h4>
                    <div class="d-flex flex-wrap gap-2">
                        @foreach (var allergen in Model.Allergens)
                        {
                            <span class="badge bg-danger text-white fs-6 px-3 py-2 rounded-pill">@allergen</span>
                        }
                    </div>
                </div>
            }

            @if (ViewBag.NutritionSummary != null)
            {
                <div class="card shadow-sm border-0 mb-4 p-4" style="background-color: #f0fdf4; border-left: 6px solid var(--accent); border-radius: 1.5rem;">
                    <h4 class="fw-bold text-success mb-3">
                        <i class="bi bi-bar-chart-line-fill me-2"></i>Nutrition Estimate (per recipe)
                    </h4>
                    <ul class="list-unstyled fs-5 mb-0 text-dark">
                        <li>🔥 Calories: <strong>@ViewBag.NutritionSummary.Calories</strong> kcal</li>
                        <li>🍗 Protein: <strong>@ViewBag.NutritionSummary.Protein</strong> g</li>
                        <li>🍚 Carbs: <strong>@ViewBag.NutritionSummary.Carbs</strong> g</li>
                        <li>🥑 Fat: <strong>@ViewBag.NutritionSummary.Fat</strong> g</li>
                    </ul>
                </div>
            }

            <!-- ✅ INGREDIENTS -->
            @if (Model.Ingredients != null && Model.Ingredients.Count > 0)
            {
                <div class="card shadow-sm border-0 p-4 mb-4" style="background-color: #f9f9f9; border-left: 6px solid var(--primary); border-radius: 1.5rem;">
                    <h4 class="fw-bold text-dark mb-3">
                        <i class="bi bi-basket-fill me-2"></i>Ingredients
                    </h4>
                    <ul class="list-group list-group-flush">
                        @foreach (var ingredient in Model.Ingredients)
                        {
                            <li class="list-group-item bg-transparent ps-0">
                                <i class="bi bi-dot text-primary me-2"></i>@ingredient
                            </li>
                        }
                    </ul>
                </div>
            }

            <!-- ✅ INSTRUCTIONS -->
            @if (!string.IsNullOrWhiteSpace(Model.Instructions))
            {
                var steps = Model.Instructions
                .Split(new[] { '\n', '\r' }, System.StringSplitOptions.RemoveEmptyEntries)
                .Select(step => step.Trim())
                .ToList();

                <div class="card shadow-sm border-0 p-4 mb-5" style="background-color: #f8fafc; border-left: 6px solid var(--primary); border-radius: 1.5rem;">
                    <h4 class="fw-bold text-primary mb-3">
                        <i class="bi bi-list-check me-2"></i>Instructions
                    </h4>
                    <ul class="list-group list-group-flush">
                        @foreach (var step in steps)
                        {
                            <li class="list-group-item bg-transparent ps-0">
                                <i class="bi bi-chevron-right text-primary me-2"></i>@step
                            </li>
                        }
                    </ul>
                </div>
            }

            <div class="text-center">
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg rounded-pill">
                    <i class="bi bi-arrow-left me-1"></i>Back to Library
                </a>
            </div>
        </div>
    </div>
</div>

<!-- Include Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
