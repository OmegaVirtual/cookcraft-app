@model Recipes.Models.AddRecipeViewModel

@{
    ViewData["Title"] = "Add New Recipe";
}

<div class="container py-5">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-5" style="color: var(--primary);">
            <i class="bi bi-plus-circle-dotted me-2"></i> Add New Recipe
        </h1>
        <p class="text-muted">Share your culinary creation with the world</p>
    </div>

    <form asp-action="Add" method="post" enctype="multipart/form-data" class="shadow p-4 rounded bg-white">
        <div class="mb-4">
            <label asp-for="Title" class="form-label fw-semibold">Recipe Title</label>
            <input asp-for="Title" class="form-control form-control-lg" placeholder="e.g. Creamy Chicken Pasta" required />
        </div>

        <div class="mb-4">
            <label asp-for="ShortDescription" class="form-label fw-semibold">Short Description</label>
            <input asp-for="ShortDescription" class="form-control form-control-lg" placeholder="Brief summary of the dish" required />
        </div>

        <div class="mb-4">
            <label asp-for="IngredientsText" class="form-label fw-semibold">Ingredients</label>
            <textarea asp-for="IngredientsText" class="form-control form-control-lg" rows="5" placeholder="- 200g chicken\n- 1 onion" required></textarea>
            <div class="form-text">List one ingredient per line.</div>
        </div>

        <div class="mb-4">
            <label asp-for="Instructions" class="form-label fw-semibold">Instructions</label>
            <textarea asp-for="Instructions" class="form-control form-control-lg" rows="6" placeholder="Step-by-step cooking guide..." required></textarea>
        </div>

        <div class="mb-4">
            <label for="ImageFile" class="form-label fw-semibold">Upload Dish Photo</label>
            <input type="file" id="ImageFile" name="ImageFile" accept="image/*" class="form-control form-control-lg" />
            <div class="form-text">Supported formats: JPG, PNG</div>
        </div>

        <div class="d-grid gap-2">
            <button type="submit" class="btn btn-lg text-white" style="background-color: var(--accent);">
                <i class="bi bi-save me-2"></i>Save Recipe
            </button>
            <a asp-action="Index" class="btn btn-outline-secondary">
                <i class="bi bi-arrow-left me-1"></i> Back to Recipe Library
            </a>
        </div>
    </form>
</div>

<!-- Include Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
