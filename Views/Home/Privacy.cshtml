@{
    ViewData["Title"] = "Privacy Policy";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<div class="container py-5 mt-5 pt-5 animate-fade" style="margin-top: 130px !important;">
    <div class="text-center mb-5">
        <h1 class="display-5 fw-bold" style="color: var(--primary);">
            <i class="bi bi-shield-lock-fill me-2"></i>Your Privacy Matters
        </h1>
        <p class="fs-5" style="color: var(--text-light);">
            At CookCraft, your data belongs to you. We’re dedicated to protecting your privacy while delivering a personalized culinary experience.
        </p>
    </div>

    <!-- Section: What We Collect -->
    <div class="card border-0 shadow-sm p-4 mb-4 rounded-4" style="background-color: #ffffff;">
        <h4 class="fw-bold mb-3" style="color: var(--primary);">
            <i class="bi bi-archive-fill me-2"></i>What We Collect
        </h4>
        <p class="text-muted">We collect only the essentials to enhance your cooking experience:</p>
        <ul class="text-muted">
            <li>👤 Profile details such as username and cooking preferences</li>
            <li>📧 Email (optional) to help with account access and support</li>
            <li>🍽️ Your recipes, achievements, and cooking history</li>
        </ul>
    </div>

    <!-- Section: How We Use It -->
    <div class="card border-0 shadow-sm p-4 mb-4 rounded-4" style="background-color: #ffffff;">
        <h4 class="fw-bold mb-3" style="color: var(--primary);">
            <i class="bi bi-lightbulb-fill me-2"></i>How We Use Your Data
        </h4>
        <p class="text-muted">Your data is used strictly to enhance your experience:</p>
        <ul class="text-muted">
            <li>📊 Generate nutrition insights tailored to your goals</li>
            <li>🏆 Personalize your progress, badges, and levels</li>
            <li>🍳 Suggest weekly challenges aligned with your preferences</li>
        </ul>
    </div>

    <!-- Section: How We Protect It -->
    <div class="card border-0 shadow-sm p-4 mb-4 rounded-4" style="background-color: #ffffff;">
        <h4 class="fw-bold mb-3" style="color: var(--primary);">
            <i class="bi bi-lock-fill me-2"></i>How We Protect Your Information
        </h4>
        <p class="text-muted">We implement robust security measures, including:</p>
        <ul class="text-muted">
            <li>🔐 HTTPS encryption across the entire platform</li>
            <li>🛡️ Industry-standard password hashing</li>
            <li>🔍 Ongoing monitoring and security patching</li>
        </ul>
    </div>

    <!-- Section: Your Rights -->
    <div class="card border-0 shadow-sm p-4 mb-4 rounded-4" style="background-color: #ffffff;">
        <h4 class="fw-bold mb-3" style="color: var(--primary);">
            <i class="bi bi-shield-check me-2"></i>Your Rights
        </h4>
        <p class="text-muted">You have the right to understand and control how your data is used. We believe in transparency and give you the ability to:</p>
        <ul class="text-muted">
            <li>📥 Review your recipe and activity history</li>
            <li>🧽 Clear your preferences or reset recommendations</li>
            <li>💡 Contact support for any privacy concerns or help</li>
        </ul>
    </div>

    <!-- Section: Contact Us -->
    <div class="card border-0 shadow-sm p-4 mb-4 rounded-4" style="background-color: #ffffff;">
        <h4 class="fw-bold mb-3" style="color: var(--primary);">
            <i class="bi bi-envelope-paper-fill me-2"></i>Contact Us
        </h4>
        <p class="text-muted">
            We're here to listen. If you have any questions about your data or our privacy practices, reach out to us anytime at
            <a href="mailto:support@cookcraft.app" class="fw-semibold" style="color: var(--accent);">maneacristian2693@yahoo.com</a>.
        </p>
    </div>

    <div class="text-center mt-4">
        <a href="/" class="btn rounded-pill px-4 fw-semibold" style="border: 2px solid var(--primary); color: var(--primary);">
            <i class="bi bi-arrow-left me-2"></i>Back to Home
        </a>
    </div>
</div>

<!-- Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
