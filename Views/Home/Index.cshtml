@{
    ViewData["Title"] = "Home";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<!-- 🌟 Hero Section with Animation -->
<div class="container py-5">
    <div class="glass-card text-center p-5 shadow-lg rounded-4 mb-5 animate-fade-slide">
        <h1 class="fw-bold mb-3 display-4" id="animatedMessage" style="color: var(--accent);">
            <i class="bi bi-stars me-2"></i>Welcome to CookCraft
        </h1>
        <p class="lead text-light mb-0">Your intelligent kitchen companion for recipes, grocery planning, and nutritional wellness.</p>
    </div>

    <!-- ✨ Premium Features Section -->
    <div class="text-center mb-4 animate-bounce">
        <h2 class="fw-bold" style="color: var(--accent); font-size: 2.2rem;">
            <i class="bi bi-lightning-charge-fill me-2"></i>Experience Premium Tools
        </h2>
        <p class="text-light">Craft smarter meals, manage allergens, and level up your cooking lifestyle.</p>
    </div>

    <div class="row row-cols-1 row-cols-md-3 g-4">
        <div class="col d-flex">
            <div class="card h-100 text-center p-4 border-0 shadow feature-card rounded-4 bg-dark text-light w-100 d-flex flex-column justify-content-between animate-fade">
                <div>
                    <div class="mb-3 display-5 glow-icon">🧠</div>
                    <h5 class="fw-bold mb-2" style="color: var(--accent);">Smart Recipe Engine</h5>
                    <p class="text-muted">Automatically detect allergens, scale ingredients, and get instant nutrition insights.</p>
                </div>
                <a href="/Recipes/Index" class="btn btn-xl premium-btn rounded-pill mt-4">📖 Explore Recipes</a>
            </div>
        </div>
        <div class="col d-flex">
            <div class="card h-100 text-center p-4 border-0 shadow feature-card rounded-4 bg-dark text-light w-100 d-flex flex-column justify-content-between animate-fade delay-1">
                <div>
                    <div class="mb-3 display-5 glow-icon">🧬</div>
                    <h5 class="fw-bold mb-2" style="color: var(--accent);">Allergen Intelligence</h5>
                    <p class="text-muted">Visualize trends, handle emergency data, and personalize allergen tracking.</p>
                </div>
                <a href="/Allergens/Index" class="btn btn-xl premium-btn rounded-pill mt-4">🔎 Manage Allergens</a>
            </div>
        </div>
        <div class="col d-flex">
            <div class="card h-100 text-center p-4 border-0 shadow feature-card rounded-4 bg-dark text-light w-100 d-flex flex-column justify-content-between animate-fade delay-2">
                <div>
                    <div class="mb-3 display-5 glow-icon">📈</div>
                    <h5 class="fw-bold mb-2" style="color: var(--accent);">Nutrition & Insights</h5>
                    <p class="text-muted">Track calories, macros, badges, and overall progress—all in one place.</p>
                </div>
                <a href="/Identity/Account/Manage/Index" class="btn btn-xl premium-btn rounded-pill mt-4">👤 View Profile</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const messages = [
            "🍽️ Welcome to CookCraft!",
            "📚 Organize and discover your favorite recipes.",
            "🔬 Analyze allergens and nutrition effortlessly.",
            "🔥 Track progress and earn achievements!"
        ];
        let index = 0;
        const msg = document.getElementById('animatedMessage');

        function rotateMessage() {
            msg.style.opacity = 0;
            setTimeout(() => {
                msg.textContent = messages[index];
                msg.style.opacity = 1;
                index = (index + 1) % messages.length;
            }, 400);
        }

        setInterval(rotateMessage, 4000);
    </script>

    <style>
        #animatedMessage {
            transition: opacity 0.5s ease-in-out;
        }

        .glass-card {
            background: rgba(31, 41, 55, 0.85);
            backdrop-filter: blur(14px);
            border-radius: 20px;
        }

        .glow-icon {
            text-shadow: 0 0 12px rgba(255, 215, 0, 0.8), 0 0 20px rgba(255, 215, 0, 0.4);
        }

        .premium-btn {
            background-color: var(--accent);
            color: #1f2937;
            font-weight: 700;
            font-size: 1.25rem;
            padding: 1rem 2rem;
            transition: all 0.3s ease-in-out;
        }

            .premium-btn:hover {
                background-color: #e6c200;
                color: #000;
                transform: scale(1.05);
            }

        .btn-xl {
            min-height: 64px;
            line-height: 1.5;
        }

        .feature-card {
            transition: transform 0.3s ease, box-shadow 0.3s ease;
        }

            .feature-card:hover {
                transform: translateY(-6px);
                box-shadow: 0 12px 30px rgba(0, 0, 0, 0.15);
            }

        /* Animations */
        .animate-fade {
            opacity: 0;
            transform: translateY(30px);
            animation: fadeInUp 1s ease forwards;
        }

            .animate-fade.delay-1 {
                animation-delay: 0.3s;
            }

            .animate-fade.delay-2 {
                animation-delay: 0.6s;
            }

        .animate-fade-slide {
            opacity: 0;
            transform: translateY(50px);
            animation: fadeSlideIn 1.2s ease forwards;
        }

        .animate-bounce {
            animation: bounceIn 1.4s ease;
        }

        @@keyframes fadeInUp {
            to

        {
            opacity: 1;
            transform: translateY(0);
        }

        }

        @@keyframes fadeSlideIn {
            to

        {
            opacity: 1;
            transform: translateY(0);
        }

        }

        @@keyframes bounceIn {
            0%

        {
            transform: scale(0.95);
            opacity: 0;
        }

        50% {
            transform: scale(1.05);
            opacity: 0.7;
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }

        }
    </style>

    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
}
