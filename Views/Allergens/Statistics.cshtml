@model IEnumerable<dynamic>

@{
    ViewData["Title"] = "Allergen Statistics";
    Layout = "~/Views/Shared/_Layout.cshtml";

    Func<string, string> getAllergenIcon = allergen =>
    {
        allergen = allergen?.ToLowerInvariant() ?? "";
        return allergen switch
        {
            var a when a.Contains("gluten") => "🥖",
            var a when a.Contains("peanut") => "🥜",
            var a when a.Contains("milk") || a.Contains("dairy") => "🥛",
            var a when a.Contains("egg") => "🥚",
            var a when a.Contains("soy") => "🌱",
            var a when a.Contains("shellfish") => "🦐",
            var a when a.Contains("fish") => "🐟",
            var a when a.Contains("tree nut") => "🌰",
            _ => "⚠️"
        };
    };
}

<div class="container py-5 pb-6">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-4" style="color: var(--primary);">
            <i class="bi bi-graph-up me-2"></i>Allergen Statistics
        </h1>
        <p class="text-muted fs-5">Visual insights into allergen frequency across your recipes.</p>
    </div>


    <!-- 📋 Summary Table -->
    <div class="row justify-content-center mb-5">
        <div class="col-md-10 col-lg-8">
            <div class="glass-card table-responsive p-4 rounded-4 shadow">
                <table class="table align-middle table-borderless mb-0">
                    <thead>
                        <tr style="color: var(--primary); font-weight: 700; font-size: 1.1rem;">
                            <th>Allergen</th>
                            <th>Recipes</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var item in Model)
                        {
                            var icon = getAllergenIcon(item.Allergen);
                            <tr class="border-top">
                                <td class="fw-semibold fs-5">@icon @item.Allergen</td>
                                <td class="text-muted fs-5">@item.Count</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>

    <!-- 🔙 Back Button -->
    <div class="text-center">
        <a asp-action="Index" class="btn btn-xl text-white rounded-pill px-5 py-3 fw-semibold" style="background-color: var(--accent); font-size: 1.2rem;">
            <i class="bi bi-arrow-left me-2"></i>Back to Allergen Management
        </a>
    </div>
</div>

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const chartLabels = [@string.Join(",", Model.Select(m => $"\"{m.Allergen}\""))];
        const chartData = [@string.Join(",", Model.Select(m => m.Count))];

        const ctx = document.getElementById('allergenChart').getContext('2d');
        new Chart(ctx, {
            type: 'bar',
            data: {
                labels: chartLabels,
                datasets: [{
                    label: 'Recipes with Allergen',
                    data: chartData,
                    backgroundColor: 'rgba(255, 215, 0, 0.7)',
                    borderColor: 'rgba(234, 179, 8, 1)',
                    borderWidth: 2,
                    borderRadius: 10,
                    hoverBackgroundColor: 'rgba(234, 179, 8, 1)'
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                animation: {
                    duration: 1000,
                    easing: 'easeOutQuart'
                },
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#1e293b',
                        titleColor: '#fff',
                        bodyColor: '#fff',
                        cornerRadius: 8,
                        padding: 12
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            color: '#1e293b',
                            font: { size: 14, weight: '500' }
                        },
                        grid: { color: '#e2e8f0' }
                    },
                    x: {
                        ticks: {
                            color: '#1e293b',
                            font: { size: 14, weight: '500' }
                        },
                        grid: { display: false }
                    }
                }
            }
        });
    </script>

    <style>
        .btn-xl {
            font-size: 1.1rem;
            padding: 0.85rem 2rem;
        }

        .container.pb-6 {
            padding-bottom: 6rem !important;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(10px);
            border-radius: 1rem;
        }

        table tbody tr:hover {
            background-color: #f1f5f9;
        }

        canvas {
            border-radius: 12px;
        }
    </style>
}

<!-- Include Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
