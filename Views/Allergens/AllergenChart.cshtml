@model List<Recipes.Models.AllergenChartViewModel>

@{
    ViewData["Title"] = "Allergen Trends";
    Layout = "~/Views/Shared/_Layout.cshtml";

    Func<string, string> getAllergenIcon = allergen =>
    {
        allergen = allergen?.ToLowerInvariant() ?? "";
        return allergen switch
        {
            var a when a.Contains("gluten") => "🥖",
            var a when a.Contains("peanut") => "🥜",
            var a when a.Contains("milk") || a.Contains("dairy") => "🥛",
            var a when a.Contains("egg") => "🥚",
            var a when a.Contains("soy") => "🌱",
            var a when a.Contains("shellfish") => "🦐",
            var a when a.Contains("fish") => "🐟",
            var a when a.Contains("tree nut") => "🌰",
            _ => "⚠️"
        };
    };
}

<div class="container py-5 pb-6">
    <div class="text-center mb-5">
        <h1 class="fw-bold display-4" style="color: var(--primary);">
            <i class="bi bi-activity me-2"></i>Allergen Trends
        </h1>
        <p class="text-muted fs-5">Track how often allergens appear in your recipes over time.</p>
    </div>

    <!-- 🧾 Allergen Detail Cards -->
    <div class="row g-4">
        @foreach (var item in Model)
        {
            var icon = getAllergenIcon(item.Allergen);
            <div class="col-md-4">
                <div class="card border-0 shadow-sm h-100 rounded-4 glass-card p-3">
                    <div class="card-body d-flex flex-column">
                        <h5 class="fw-bold fs-4 mb-2" style="color: var(--primary);">
                            @icon @item.Allergen
                        </h5>
                        <p class="text-muted mb-2 fs-6">
                            <i class="bi bi-clipboard-data me-1"></i>Recipes Detected: <strong>@item.Count</strong>
                        </p>
                        <span class="badge @GetCommonnessClass(item.Commonness) px-3 py-2 rounded-pill fs-6 mt-auto">
                            @item.Commonness
                        </span>
                    </div>
                </div>
            </div>
        }
    </div>

    <!-- 🔙 Back Button -->
    <div class="text-center mt-5">
        <a asp-action="Index" class="btn btn-xl text-white rounded-pill px-5 py-3 fw-semibold" style="background-color: var(--accent); font-size: 1.2rem;">
            <i class="bi bi-arrow-left me-2"></i>Back to Allergen Management
        </a>
    </div>
</div>

@functions {
    string GetCommonnessClass(string label)
    {
        return label switch
        {
            "🔥 Very Common" => "bg-danger text-white",
            "⚠️ Common" => "bg-warning text-dark",
            _ => "bg-secondary text-white"
        };
    }
}

@section Scripts {
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
        const ctx = document.getElementById('allergenChart').getContext('2d');
        new Chart(ctx, {
            type: 'line',
            data: {
                labels: [@string.Join(",", Model.Select(m => $"\"{m.Allergen}\""))],
                datasets: [{
                    label: 'Recipe Count',
                    data: [@string.Join(",", Model.Select(m => m.Count))],
                    fill: true,
                    backgroundColor: 'rgba(56, 189, 248, 0.15)',
                    borderColor: 'rgba(14, 116, 144, 1)',
                    tension: 0.4,
                    pointBackgroundColor: 'rgba(14, 116, 144, 1)',
                    pointRadius: 5,
                    pointHoverRadius: 7
                }]
            },
            options: {
                responsive: true,
                maintainAspectRatio: false,
                plugins: {
                    legend: { display: false },
                    tooltip: {
                        backgroundColor: '#1e293b',
                        titleColor: '#fefefe',
                        bodyColor: '#fefefe',
                        cornerRadius: 8,
                        padding: 12
                    }
                },
                scales: {
                    y: {
                        beginAtZero: true,
                        ticks: {
                            color: '#1e293b',
                            font: { size: 14 }
                        },
                        grid: {
                            color: '#e5e7eb'
                        }
                    },
                    x: {
                        ticks: {
                            color: '#1e293b',
                            font: { size: 14 }
                        },
                        grid: {
                            display: false
                        }
                    }
                }
            }
        });
    </script>

    <style>
        .btn-xl {
            font-size: 1.1rem;
            padding: 0.9rem 2rem;
        }

        .container.pb-6 {
            padding-bottom: 6rem !important;
        }

        .glass-card {
            background: rgba(255, 255, 255, 0.75);
            backdrop-filter: blur(10px);
        }

        canvas {
            border-radius: 12px;
        }
    </style>
}

<!-- Include Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
