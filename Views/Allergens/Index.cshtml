@model IEnumerable<Recipes.Models.Allergen>
@using Microsoft.AspNetCore.Identity
@inject UserManager<ApplicationUser> UserManager

@{
    ViewData["Title"] = "Allergen Management";
    var user = User.Identity.IsAuthenticated ? await UserManager.GetUserAsync(User) : null;
}

<div class="text-center py-5 pb-6">
    <h1 class="fw-bold display-5" style="color: var(--primary);">
        <i class="bi bi-shield-exclamation me-2"></i>Allergen Management
    </h1>
    <p class="text-muted fs-5">Learn and control allergens across your recipes.</p>

    <!-- 🔍 Search Bar -->
    <div class="mb-4 d-flex justify-content-center">
        <input id="searchBox" type="text" class="form-control shadow-sm rounded-pill px-4 py-3 fs-5" style="max-width: 400px;" placeholder="Search allergens... 🔍" onkeyup="filterAllergens()" />
    </div>

    <!-- 📈 Statistics + Trends Buttons -->
    <div class="d-flex justify-content-center gap-3 mb-5">
        <a asp-action="Statistics" class="btn btn-xl btn-success rounded-pill px-5 py-3 fw-semibold fs-5">
            <i class="bi bi-pie-chart-fill me-2"></i>Allergen Statistics
        </a>
        <a asp-action="Trends" class="btn btn-xl btn-outline-success rounded-pill px-5 py-3 fw-semibold fs-5">
            <i class="bi bi-graph-up-arrow me-2"></i>Allergen Trends
        </a>
    </div>

    <!-- ➕ Add New Allergen Form (Hidden) -->
    <div class="">
        <form asp-action="Add" method="post" class="row justify-content-center g-3 mb-5">
            <div class="col-md-3">
                <input type="text" name="name" class="form-control rounded-pill px-4 py-3 fs-5" placeholder="New allergen name..." required />
            </div>
            <div class="col-md-4">
                <input type="text" name="description" class="form-control rounded-pill px-4 py-3 fs-5" placeholder="Description..." />
            </div>
            <div class="col-md-2 d-grid">
                <button type="submit" class="btn btn-xl text-white rounded-pill fw-semibold px-4 py-3 fs-5" style="background-color: var(--accent);">
                    <i class="bi bi-plus-circle me-1"></i>Add Allergen
                </button>
            </div>
        </form>
    </div>
</div>

<!-- 🔥 Display Allergens List -->
<div class="container pb-6">
    <div class="row row-cols-1 row-cols-md-2 g-4" id="allergenList">
        @foreach (var allergen in Model)
        {
            var canDelete = user != null && (allergen.ApplicationUserId == user.Id || User.IsInRole("Admin"));

            <div class="col allergen-card">
                <div class="card h-100 shadow-sm border-0 rounded-4 bg-light">
                    <div class="card-body d-flex flex-column">
                        <h4 class="fw-bold mb-2" style="color: var(--primary);">
                            <i class="bi bi-exclamation-circle text-danger me-2"></i>@allergen.Name
                        </h4>
                        <p class="text-muted small">@allergen.Description</p>

                        <div class="mt-auto d-flex justify-content-between align-items-center pt-3">
                            @if (canDelete)
                            {
                                <form asp-action="Delete" asp-route-id="@allergen.Id" method="post">
                                    <button type="submit" class="btn btn-xl btn-outline-danger rounded-pill px-4 py-2 fs-6">
                                        <i class="bi bi-trash me-1"></i>Delete
                                    </button>
                                </form>
                            }
                            <div class="d-flex gap-2">
                                <a asp-action="ViewRecipes" asp-route-allergenName="@allergen.Name" class="btn btn-xl btn-outline-primary rounded-pill px-4 py-2 fs-6">
                                    <i class="bi bi-book me-1"></i>View Recipes
                                </a>
                                <a asp-action="EmergencyAction" asp-route-allergenName="@allergen.Name" class="btn btn-xl btn-outline-warning rounded-pill px-4 py-2 fs-6">
                                    <i class="bi bi-activity me-1"></i>Emergency Info
                                </a>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>
</div>

@section Scripts {
    <script>
        function filterAllergens() {
            const input = document.getElementById("searchBox").value.toLowerCase();
            const cards = document.querySelectorAll(".allergen-card");

            cards.forEach(card => {
                const name = card.querySelector("h4").textContent.toLowerCase();
                const description = card.querySelector("p").textContent.toLowerCase();
                const matches = name.includes(input) || description.includes(input);
                card.style.display = matches ? "block" : "none";
            });
        }
    </script>

    <style>
        .btn-xl {
            font-size: 1.1rem;
            padding: 0.75rem 1.25rem;
        }

        .container.pb-6 {
            padding-bottom: 6rem !important;
        }
    </style>
}

<!-- Include Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
