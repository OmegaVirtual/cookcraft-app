@model IEnumerable<Recipes.Models.Recipe>

@{
    ViewData["Title"] = "Recipes with " + ViewBag.AllergenName;
}

<div class="text-center py-5">
    <h1 class="fw-bold display-5" style="color: var(--primary);">
        <i class="bi bi-bandaid me-2"></i>Recipes with @ViewBag.AllergenName
    </h1>

    @if (!Model.Any())
    {
        <p class="text-muted fs-5">No recipes found with this allergen.</p>
    }
</div>

@if (Model.Any())
{
    <div class="container pb-5">
        <div class="row row-cols-1 row-cols-md-2 row-cols-lg-3 g-4">
            @foreach (var recipe in Model)
            {
                <div class="col">
                    <div class="card h-100 shadow-sm border-0 rounded-4 overflow-hidden">
                        <img src="@recipe.ImageUrl" class="card-img-top" alt="Recipe Image" style="height: 250px; object-fit: cover;">
                        <div class="card-body text-center">
                            <h5 class="card-title fw-bold" style="color: var(--primary);">
                                <i class="bi bi-journal-text me-1"></i>@recipe.Title
                            </h5>
                            <p class="text-muted" style="min-height: 60px;">@recipe.ShortDescription</p>
                            <a asp-controller="Recipes" asp-action="View" asp-route-id="@recipe.Id" class="btn btn-outline-success rounded-pill px-4">
                                <i class="bi bi-book me-1"></i>View Recipe
                            </a>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
}

<div class="text-center pb-5">
    <a asp-controller="Allergens" asp-action="Index" class="btn btn-lg text-white rounded-pill px-4 py-2" style="background-color: var(--accent);">
        <i class="bi bi-arrow-left me-2"></i>Back to Allergen Management
    </a>
</div>

<!-- Include Bootstrap Icons -->
<link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.5/font/bootstrap-icons.css">
